<UserControl x:Class="bankova_aplikacia.Asistent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{DynamicResource HlavnyBg}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{DynamicResource PanelBg}"
                BorderBrush="{DynamicResource PanelBorder}"
                BorderThickness="0,0,0,1"
                Padding="28,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Avatar -->
                <Border Grid.Column="0"
                        Width="44" Height="44"
                        CornerRadius="22"
                        Background="#111111"
                        Margin="0,0,14,0">
                    <TextBlock Text="AI"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="Investičný Asistent"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource HlavnyText}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                        <Ellipse Width="7" Height="7"
                                 Fill="#34C759"
                                 VerticalAlignment="Center"
                                 Margin="0,0,6,0"/>
                        <TextBlock Text="Online · Gemini 2.5 Flash"
                                   FontSize="12"
                                   Foreground="{DynamicResource SekundarnyText}"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- API key bar -->
        <Border x:Name="ApiKeyPanel"
                Grid.Row="1"
                Padding="20,10"
                Background="#FFF9E6"
                BorderBrush="#FFE082"
                BorderThickness="0,0,0,1"
                Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="🔑  Gemini API kľúč:"
                           FontSize="13"
                           Foreground="#856404"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"/>
                <PasswordBox x:Name="TxtApiKey"
                             Grid.Column="1"
                             FontSize="13"
                             Height="34"
                             VerticalContentAlignment="Center"
                             Padding="10,0"
                             Background="White"
                             BorderBrush="#FFE082"
                             BorderThickness="1"/>
                <Button Grid.Column="2"
                        Click="BtnUlozKluc_Click"
                        Content="Uložiť"
                        Height="34"
                        Width="80"
                        FontSize="13"
                        Margin="8,0,0,0"
                        Background="#111111"
                        Foreground="White"
                        BorderThickness="0"/>
            </Grid>
        </Border>

        <!-- Chat area -->
        <ScrollViewer x:Name="ScrollChat"
                      Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      Padding="28,20,28,8">
            <StackPanel x:Name="PanelSprav"/>
        </ScrollViewer>

        <!-- Input bar -->
        <Border Grid.Row="3"
                Padding="20,14"
                Background="{DynamicResource PanelBg}"
                BorderBrush="{DynamicResource PanelBorder}"
                BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0"
                        Background="{DynamicResource HlavnyBg}"
                        BorderBrush="{DynamicResource PanelBorder}"
                        BorderThickness="1"
                        CornerRadius="22"
                        Padding="16,0">
                    <TextBox x:Name="TxtVstup"
                             FontSize="14"
                             Height="44"
                             VerticalContentAlignment="Center"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="{DynamicResource HlavnyText}"
                             KeyDown="TxtVstup_KeyDown"/>
                </Border>
                <Button x:Name="BtnPoslat"
                        Grid.Column="1"
                        Click="BtnPoslat_Click"
                        Width="48" Height="48"
                        Margin="10,0,0,0"
                        Background="#111111"
                        BorderThickness="0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="24">
                                <TextBlock Text="↑"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="White"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- Spinner overlay -->
        <Grid x:Name="SpinnerOverlay"
              Grid.Row="2"
              Background="{DynamicResource SpinnerBg}"
              Visibility="Collapsed">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border Width="48" Height="48">
                    <Border.RenderTransform>
                        <RotateTransform x:Name="SpinnerRotate" CenterX="24" CenterY="24"/>
                    </Border.RenderTransform>
                    <Border.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetName="SpinnerRotate"
                                                     Storyboard.TargetProperty="Angle"
                                                     From="0" To="360"
                                                     Duration="0:0:0.8"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Border.Triggers>
                    <Ellipse Width="48" Height="48"
                             Stroke="#111111"
                             StrokeThickness="4"
                             StrokeDashArray="10 5"/>
                </Border>
                <TextBlock x:Name="TxtSpinnerText"
                           Text="Načítavam kontext..."
                           Margin="0,12,0,0"
                           FontSize="13"
                           Foreground="{DynamicResource SekundarnyText}"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>

    </Grid>
</UserControl>
