<UserControl x:Class="bankova_aplikacia.Asistent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- API key bar -->
        <Border x:Name="ApiKeyPanel"
                Grid.Row="0"
                Padding="20,10"
                Background="{DynamicResource PanelBg}"
                BorderBrush="{DynamicResource PanelBorder}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="Gemini API kľúč:"
                           FontSize="13"
                           Foreground="{DynamicResource SekundarnyText}"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"/>
                <PasswordBox x:Name="TxtApiKey"
                             Grid.Column="1"
                             FontSize="13"
                             Height="32"
                             VerticalContentAlignment="Center"
                             Padding="8,0"
                             Background="{DynamicResource PolozkaBg}"
                             Foreground="{DynamicResource HlavnyText}"
                             BorderBrush="{DynamicResource PanelBorder}"
                             BorderThickness="1"/>
                <Button Grid.Column="2"
                        Click="BtnUlozKluc_Click"
                        Content="Uložiť"
                        Height="32"
                        Width="80"
                        FontSize="13"
                        Margin="8,0,0,0"
                        Background="#1A1A1A"
                        Foreground="White"
                        BorderThickness="0"/>
            </Grid>
        </Border>

        <!-- Chat area -->
        <ScrollViewer x:Name="ScrollChat"
                      Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      Padding="24,12">
            <StackPanel x:Name="PanelSprav"/>
        </ScrollViewer>

        <!-- Input bar -->
        <Border Grid.Row="2"
                Padding="16,12"
                Background="{DynamicResource PanelBg}"
                BorderBrush="{DynamicResource PanelBorder}"
                BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TxtVstup"
                         Grid.Column="0"
                         FontSize="14"
                         Height="40"
                         VerticalContentAlignment="Center"
                         Padding="10,0"
                         Background="{DynamicResource PolozkaBg}"
                         Foreground="{DynamicResource HlavnyText}"
                         BorderBrush="{DynamicResource PanelBorder}"
                         BorderThickness="1"
                         KeyDown="TxtVstup_KeyDown"/>
                <Button x:Name="BtnPoslat"
                        Grid.Column="1"
                        Click="BtnPoslat_Click"
                        Content="Odoslať"
                        Height="40"
                        Width="90"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Margin="8,0,0,0"
                        Background="#1A1A1A"
                        Foreground="White"
                        BorderThickness="0"/>
            </Grid>
        </Border>

        <!-- Spinner overlay (over chat area) -->
        <Grid x:Name="SpinnerOverlay"
              Grid.Row="1"
              Background="{DynamicResource SpinnerBg}"
              Visibility="Collapsed">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border Width="50" Height="50">
                    <Border.RenderTransform>
                        <RotateTransform x:Name="SpinnerRotate" CenterX="25" CenterY="25"/>
                    </Border.RenderTransform>
                    <Border.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetName="SpinnerRotate"
                                                     Storyboard.TargetProperty="Angle"
                                                     From="0" To="360"
                                                     Duration="0:0:0.8"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Border.Triggers>
                    <Ellipse Width="50" Height="50"
                             Stroke="#1A1A1A"
                             StrokeThickness="4"
                             StrokeDashArray="10 5"/>
                </Border>
                <TextBlock x:Name="TxtSpinnerText"
                           Text="Načítavam kontext..."
                           Margin="0,10,0,0"
                           FontSize="13"
                           Foreground="{DynamicResource StrednyText}"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>

    </Grid>
</UserControl>
