<UserControl x:Class="bankova_aplikacia.Historia"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <ItemsControl x:Name="ZoznamHistorie" Margin="30,20">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Padding="20"
                            Margin="0,0,0,16"
                            Background="{DynamicResource PanelBg}"
                            BorderBrush="{DynamicResource PanelBorder}"
                            BorderThickness="1"
                            CornerRadius="10">
                        <StackPanel>

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding Datum}"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource HlavnyText}"
                                           VerticalAlignment="Center"/>
                                <Border Grid.Column="1"
                                        Padding="10,5"
                                        CornerRadius="6"
                                        Background="{Binding TypFarba}">
                                    <TextBlock Text="{Binding Typ}"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="White"/>
                                </Border>
                            </Grid>

                            <Border Height="1" Background="{DynamicResource Oddelovac}" Margin="0,0,0,12"/>

                            <ItemsControl ItemsSource="{Binding Polozky}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="10,6"
                                                Margin="0,0,8,8"
                                                Background="{DynamicResource PolozkaBg}"
                                                CornerRadius="6">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Kluc}"
                                                           FontSize="13"
                                                           Foreground="{DynamicResource SekundarnyText}"/>
                                                <TextBlock Text="  " FontSize="13"/>
                                                <TextBlock Text="{Binding Hodnota}"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource HlavnyText}"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </ScrollViewer>
</UserControl>
