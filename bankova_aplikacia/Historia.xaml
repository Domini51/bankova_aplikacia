<UserControl x:Class="bankova_aplikacia.Historia"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#F5F5F7">
        <ItemsControl x:Name="ZoznamHistorie" Margin="30,24">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Background="White" CornerRadius="12" Padding="20"
                            Margin="0,0,0,14" BorderBrush="#EBEBEB" BorderThickness="1">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <Border Width="3" Height="16" Background="#1A1A1A"
                                            CornerRadius="2" Margin="0,0,10,0"/>
                                    <TextBlock Text="{Binding Datum}" FontSize="15"
                                               FontWeight="SemiBold" Foreground="#1A1A1A"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <Border Grid.Column="1" Background="#1A1A1A"
                                        CornerRadius="8" Padding="14,7">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="6" Height="6" Fill="White"
                                                 VerticalAlignment="Center" Margin="0,0,7,0"/>
                                        <TextBlock Text="{Binding Celkom}" FontSize="13"
                                                   FontWeight="SemiBold" Foreground="White"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                            <Border Height="1" Background="#F0F0F0" Margin="0,0,0,12"/>
                            <WrapPanel>
                                <Border Background="#F5F5F5" CornerRadius="6" Padding="10,6" Margin="0,0,8,8">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="SPY  " FontSize="12" Foreground="#888888"/>
                                        <TextBlock Text="{Binding SPY}" FontSize="12" FontWeight="SemiBold" Foreground="#1A1A1A"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="#F5F5F5" CornerRadius="6" Padding="10,6" Margin="0,0,8,8">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="URTH  " FontSize="12" Foreground="#888888"/>
                                        <TextBlock Text="{Binding URTH}" FontSize="12" FontWeight="SemiBold" Foreground="#1A1A1A"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="#F5F5F5" CornerRadius="6" Padding="10,6" Margin="0,0,8,8">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="AAPL  " FontSize="12" Foreground="#888888"/>
                                        <TextBlock Text="{Binding AAPL}" FontSize="12" FontWeight="SemiBold" Foreground="#1A1A1A"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="#F5F5F5" CornerRadius="6" Padding="10,6" Margin="0,0,8,8">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="TSLA  " FontSize="12" Foreground="#888888"/>
                                        <TextBlock Text="{Binding TSLA}" FontSize="12" FontWeight="SemiBold" Foreground="#1A1A1A"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="#F5F5F5" CornerRadius="6" Padding="10,6" Margin="0,0,8,8">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="NVDA  " FontSize="12" Foreground="#888888"/>
                                        <TextBlock Text="{Binding NVDA}" FontSize="12" FontWeight="SemiBold" Foreground="#1A1A1A"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="#F5F5F5" CornerRadius="6" Padding="10,6" Margin="0,0,8,8">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="BTC  " FontSize="12" Foreground="#888888"/>
                                        <TextBlock Text="{Binding BTC}" FontSize="12" FontWeight="SemiBold" Foreground="#1A1A1A"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="#F5F5F5" CornerRadius="6" Padding="10,6" Margin="0,0,8,8">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="ETH  " FontSize="12" Foreground="#888888"/>
                                        <TextBlock Text="{Binding ETH}" FontSize="12" FontWeight="SemiBold" Foreground="#1A1A1A"/>
                                    </StackPanel>
                                </Border>
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </ScrollViewer>
</UserControl>