<UserControl x:Class="bankova_aplikacia.Historia"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <ItemsControl x:Name="ZoznamHistorie" Margin="30,20">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Padding="20"
                            Margin="0,0,0,16"
                            Background="{DynamicResource PanelBg}"
                            BorderBrush="{DynamicResource PanelBorder}"
                            BorderThickness="1"
                            CornerRadius="10">
                        <StackPanel>

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding Datum}"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource HlavnyText}"
                                           VerticalAlignment="Center"/>
                                <Border Grid.Column="1"
                                        Padding="12,6"
                                        Background="#1A1A1A"
                                        CornerRadius="6">
                                    <TextBlock Text="{Binding Celkom}"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="White"/>
                                </Border>
                            </Grid>

                            <Border Height="1" Background="{DynamicResource Oddelovac}" Margin="0,0,0,12"/>

                            <WrapPanel>

                                <Border Padding="10,6"
                                        Margin="0,0,8,8"
                                        Background="{DynamicResource PolozkaBg}"
                                        CornerRadius="6">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="SPY  " FontSize="13" Foreground="{DynamicResource SekundarnyText}"/>
                                        <TextBlock Text="{Binding SPY}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource HlavnyText}"/>
                                    </StackPanel>
                                </Border>

                                <Border Padding="10,6"
                                        Margin="0,0,8,8"
                                        Background="{DynamicResource PolozkaBg}"
                                        CornerRadius="6">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="URTH  " FontSize="13" Foreground="{DynamicResource SekundarnyText}"/>
                                        <TextBlock Text="{Binding URTH}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource HlavnyText}"/>
                                    </StackPanel>
                                </Border>

                                <Border Padding="10,6"
                                        Margin="0,0,8,8"
                                        Background="{DynamicResource PolozkaBg}"
                                        CornerRadius="6">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="AAPL  " FontSize="13" Foreground="{DynamicResource SekundarnyText}"/>
                                        <TextBlock Text="{Binding AAPL}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource HlavnyText}"/>
                                    </StackPanel>
                                </Border>

                                <Border Padding="10,6"
                                        Margin="0,0,8,8"
                                        Background="{DynamicResource PolozkaBg}"
                                        CornerRadius="6">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="TSLA  " FontSize="13" Foreground="{DynamicResource SekundarnyText}"/>
                                        <TextBlock Text="{Binding TSLA}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource HlavnyText}"/>
                                    </StackPanel>
                                </Border>

                                <Border Padding="10,6"
                                        Margin="0,0,8,8"
                                        Background="{DynamicResource PolozkaBg}"
                                        CornerRadius="6">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="NVDA  " FontSize="13" Foreground="{DynamicResource SekundarnyText}"/>
                                        <TextBlock Text="{Binding NVDA}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource HlavnyText}"/>
                                    </StackPanel>
                                </Border>

                                <Border Padding="10,6"
                                        Margin="0,0,8,8"
                                        Background="{DynamicResource PolozkaBg}"
                                        CornerRadius="6">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="BTC  " FontSize="13" Foreground="{DynamicResource SekundarnyText}"/>
                                        <TextBlock Text="{Binding BTC}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource HlavnyText}"/>
                                    </StackPanel>
                                </Border>

                                <Border Padding="10,6"
                                        Margin="0,0,8,8"
                                        Background="{DynamicResource PolozkaBg}"
                                        CornerRadius="6">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="ETH  " FontSize="13" Foreground="{DynamicResource SekundarnyText}"/>
                                        <TextBlock Text="{Binding ETH}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource HlavnyText}"/>
                                    </StackPanel>
                                </Border>

                            </WrapPanel>

                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </ScrollViewer>
</UserControl>