<Window x:Class="bankova_aplikacia.HistoriaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowState="Maximized"
        Title="Investičná Banka - História" Height="900" Width="900"
        Background="#F5F5F5">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HLAVICKA -->
        <Border Grid.Row="0" Background="White" BorderBrush="#D0D0D0" BorderThickness="0,0,0,1" Padding="30,20">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="← Späť" Width="90" Height="36"
                        Background="#1A1A1A" Foreground="White"
                        FontSize="14" BorderThickness="0"
                        Click="BtnSpat_Click" Margin="0,0,20,0"/>
                <TextBlock Text="História investícií" FontSize="26"
                           FontWeight="SemiBold" Foreground="#1A1A1A"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- ZOZNAM KARIET -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="30,20">
            <ItemsControl x:Name="ZoznamHistorie">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="White" CornerRadius="10" Padding="20"
                                Margin="0,0,0,15" BorderBrush="#D0D0D0" BorderThickness="1">
                            <StackPanel>

                                <!-- DATUM A CELKOM -->
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Datum}"
                                               FontSize="16" FontWeight="SemiBold"
                                               Foreground="#1A1A1A" VerticalAlignment="Center"/>
                                    <Border Grid.Column="1" Background="#1A1A1A"
                                            CornerRadius="6" Padding="12,6">
                                        <TextBlock Text="{Binding Celkom}"
                                                   FontSize="15" FontWeight="SemiBold"
                                                   Foreground="White"/>
                                    </Border>
                                </Grid>

                                <!-- Separovanie -->
                                <Border Height="1" Background="#E0E0E0" Margin="0,0,0,12"/>

                                <!--popis -->
                                <WrapPanel>
                                    <Border Background="#F5F5F5" CornerRadius="6" Padding="10,6" Margin="0,0,8,8">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="SPY  " FontSize="13" Foreground="#888888"/>
                                            <TextBlock Text="{Binding SPY}" FontSize="13" FontWeight="SemiBold" Foreground="#1A1A1A"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Background="#F5F5F5" CornerRadius="6" Padding="10,6" Margin="0,0,8,8">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="URTH  " FontSize="13" Foreground="#888888"/>
                                            <TextBlock Text="{Binding URTH}" FontSize="13" FontWeight="SemiBold" Foreground="#1A1A1A"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Background="#F5F5F5" CornerRadius="6" Padding="10,6" Margin="0,0,8,8">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="AAPL  " FontSize="13" Foreground="#888888"/>
                                            <TextBlock Text="{Binding AAPL}" FontSize="13" FontWeight="SemiBold" Foreground="#1A1A1A"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Background="#F5F5F5" CornerRadius="6" Padding="10,6" Margin="0,0,8,8">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="TSLA  " FontSize="13" Foreground="#888888"/>
                                            <TextBlock Text="{Binding TSLA}" FontSize="13" FontWeight="SemiBold" Foreground="#1A1A1A"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Background="#F5F5F5" CornerRadius="6" Padding="10,6" Margin="0,0,8,8">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="NVDA  " FontSize="13" Foreground="#888888"/>
                                            <TextBlock Text="{Binding NVDA}" FontSize="13" FontWeight="SemiBold" Foreground="#1A1A1A"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Background="#F5F5F5" CornerRadius="6" Padding="10,6" Margin="0,0,8,8">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="BTC  " FontSize="13" Foreground="#888888"/>
                                            <TextBlock Text="{Binding BTC}" FontSize="13" FontWeight="SemiBold" Foreground="#1A1A1A"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Background="#F5F5F5" CornerRadius="6" Padding="10,6" Margin="0,0,8,8">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="ETH  " FontSize="13" Foreground="#888888"/>
                                            <TextBlock Text="{Binding ETH}" FontSize="13" FontWeight="SemiBold" Foreground="#1A1A1A"/>
                                        </StackPanel>
                                    </Border>
                                </WrapPanel>

                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

    </Grid>
</Window>