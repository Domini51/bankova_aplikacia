<Window x:Class="bankova_aplikacia.InvestWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowState="Maximized"
        Title="Investičná Banka - Investície" Height="900" Width="900"
        Background="#F5F5F5">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,0,0,-6">
        <StackPanel Margin="30,20">

            <!-- HLAVICKA -->
            <TextBlock Text="Investičný prehľad" FontSize="28" FontWeight="SemiBold"
                       Foreground="#1A1A1A" Margin="0,0,0,5"/>
            <TextBlock x:Name="TxtZostatok" Text="Dostupný zostatok: 0 €"
                       FontSize="16" Foreground="#888888" Margin="0,0,0,20"/>

            <!-- SPORIACI UCET -->
            <Border Background="White" CornerRadius="10" Padding="20" Margin="0,0,0,20"
                    BorderBrush="#D0D0D0" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Sporiaci účet (30% z príjmu)" FontSize="22"
                               FontWeight="SemiBold" Foreground="#1A1A1A" Margin="0,0,0,10"/>
                    <TextBlock x:Name="TxtSporiaci" Text="Odporúčaná suma: 0 €"
                               FontSize="18" Foreground="#555555"/>
                </StackPanel>
            </Border>

            <!-- ETF -->
            <Border Background="White" CornerRadius="10" Padding="20" Margin="0,0,0,20"
                    BorderBrush="#D0D0D0" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="ETF" FontSize="22" FontWeight="SemiBold"
                               Foreground="#1A1A1A" Margin="0,0,0,10"/>

                    <!-- S&P 500 -->
                    <Border Background="#F5F5F5" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="150"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="S&amp;P 500 (SPY)" FontSize="16" FontWeight="SemiBold" Foreground="#1A1A1A"/>
                                <TextBlock x:Name="TxtSPY" Text="Načítavam..." FontSize="14" Foreground="#888888"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="% zostatku" FontSize="12" Foreground="#888888" HorizontalAlignment="Center"/>
                                <Slider x:Name="SliderSPY" Minimum="0" Maximum="100" Value="0"
                                        Width="140" ValueChanged="Slider_Changed"/>
                                <TextBlock x:Name="TxtSPYPercent" Text="0%" FontSize="14"
                                           FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="#1A1A1A"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- MSCI World -->
                    <Border Background="#F5F5F5" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="150"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="MSCI World (URTH)" FontSize="16" FontWeight="SemiBold" Foreground="#1A1A1A"/>
                                <TextBlock x:Name="TxtURTH" Text="Načítavam..." FontSize="14" Foreground="#888888"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="% zostatku" FontSize="12" Foreground="#888888" HorizontalAlignment="Center"/>
                                <Slider x:Name="SliderURTH" Minimum="0" Maximum="100" Value="0"
                                        Width="140" ValueChanged="Slider_Changed"/>
                                <TextBlock x:Name="TxtURTHPercent" Text="0%" FontSize="14"
                                           FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="#1A1A1A"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                </StackPanel>
            </Border>

            <!-- AKCIE -->
            <Border Background="White" CornerRadius="10" Padding="20" Margin="0,0,0,20"
                    BorderBrush="#D0D0D0" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Akcie" FontSize="22" FontWeight="SemiBold"
                               Foreground="#1A1A1A" Margin="0,0,0,10"/>

                    <!-- Apple -->
                    <Border Background="#F5F5F5" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="150"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Apple (AAPL)" FontSize="16" FontWeight="SemiBold" Foreground="#1A1A1A"/>
                                <TextBlock x:Name="TxtAAPL" Text="Načítavam..." FontSize="14" Foreground="#888888"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="% zostatku" FontSize="12" Foreground="#888888" HorizontalAlignment="Center"/>
                                <Slider x:Name="SliderAAPL" Minimum="0" Maximum="100" Value="0"
                                        Width="140" ValueChanged="Slider_Changed"/>
                                <TextBlock x:Name="TxtAAPLPercent" Text="0%" FontSize="14"
                                           FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="#1A1A1A"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Tesla -->
                    <Border Background="#F5F5F5" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="150"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Tesla (TSLA)" FontSize="16" FontWeight="SemiBold" Foreground="#1A1A1A"/>
                                <TextBlock x:Name="TxtTSLA" Text="Načítavam..." FontSize="14" Foreground="#888888"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="% zostatku" FontSize="12" Foreground="#888888" HorizontalAlignment="Center"/>
                                <Slider x:Name="SliderTSLA" Minimum="0" Maximum="100" Value="0"
                                        Width="140" ValueChanged="Slider_Changed"/>
                                <TextBlock x:Name="TxtTSLAPercent" Text="0%" FontSize="14"
                                           FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="#1A1A1A"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- NVIDIA -->
                    <Border Background="#F5F5F5" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="150"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="NVIDIA (NVDA)" FontSize="16" FontWeight="SemiBold" Foreground="#1A1A1A"/>
                                <TextBlock x:Name="TxtNVDA" Text="Načítavam..." FontSize="14" Foreground="#888888"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="% zostatku" FontSize="12" Foreground="#888888" HorizontalAlignment="Center"/>
                                <Slider x:Name="SliderNVDA" Minimum="0" Maximum="100" Value="0"
                                        Width="140" ValueChanged="Slider_Changed"/>
                                <TextBlock x:Name="TxtNVDAPercent" Text="0%" FontSize="14"
                                           FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="#1A1A1A"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                </StackPanel>
            </Border>

            <!-- KRYPTO -->
            <Border Background="White" CornerRadius="10" Padding="20" Margin="0,0,0,20"
                    BorderBrush="#D0D0D0" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Kryptomeny" FontSize="22" FontWeight="SemiBold"
                               Foreground="#1A1A1A" Margin="0,0,0,10"/>

                    <!-- Bitcoin -->
                    <Border Background="#F5F5F5" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="150"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Bitcoin (BTC)" FontSize="16" FontWeight="SemiBold" Foreground="#1A1A1A"/>
                                <TextBlock x:Name="TxtBTC" Text="Načítavam..." FontSize="14" Foreground="#888888"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="% zostatku" FontSize="12" Foreground="#888888" HorizontalAlignment="Center"/>
                                <Slider x:Name="SliderBTC" Minimum="0" Maximum="100" Value="0"
                                        Width="140" ValueChanged="Slider_Changed"/>
                                <TextBlock x:Name="TxtBTCPercent" Text="0%" FontSize="14"
                                           FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="#1A1A1A"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Ethereum -->
                    <Border Background="#F5F5F5" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="150"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Ethereum (ETH)" FontSize="16" FontWeight="SemiBold" Foreground="#1A1A1A"/>
                                <TextBlock x:Name="TxtETH" Text="Načítavam..." FontSize="14" Foreground="#888888"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="% zostatku" FontSize="12" Foreground="#888888" HorizontalAlignment="Center"/>
                                <Slider x:Name="SliderETH" Minimum="0" Maximum="100" Value="0"
                                        Width="140" ValueChanged="Slider_Changed"/>
                                <TextBlock x:Name="TxtETHPercent" Text="0%" FontSize="14"
                                           FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="#1A1A1A"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                </StackPanel>
            </Border>

            <!-- SUHRN INVESTICII -->
            <Border Background="White" CornerRadius="10" Padding="20" Margin="0,0,0,20"
                    BorderBrush="#D0D0D0" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Súhrn investícií" FontSize="22" FontWeight="SemiBold"
                               Foreground="#1A1A1A" Margin="0,0,0,15"/>
                    <TextBlock x:Name="TxtCelkovePercento" Text="Celkovo alokované: 0%"
                               FontSize="16" Foreground="#555555" Margin="0,0,0,5"/>
                    <TextBlock x:Name="TxtCelkovaSuma" Text="Celková suma: 0 €"
                               FontSize="16" Foreground="#555555" Margin="0,0,0,15"/>
                    <ProgressBar x:Name="ProgressInvest" Height="20" Minimum="0" Maximum="100"
                                 Value="0" Background="#E0E0E0" BorderThickness="0" Margin="0,0,0,15"/>
                    <Button Content="Potvrdiť investície"
                            Height="46"
                            Background="#1A1A1A" Foreground="White"
                            FontSize="16" FontWeight="SemiBold" BorderThickness="0"
                            Click="BtnPotvrdit_Click"/>
                </StackPanel>
            </Border>

            <!-- HISTORIA INVESTICII -->
            <Border Background="White" CornerRadius="10" Padding="20" Margin="0,0,0,20"
                    BorderBrush="#D0D0D0" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="História investícií" FontSize="22" FontWeight="SemiBold"
                               Foreground="#1A1A1A" Margin="0,0,0,15"/>
                    
                    <Button Content="Načítať históriu"
                            Height="46" Margin="0,15,0,0"
                            Background="#555555" Foreground="White"
                            FontSize="16" FontWeight="SemiBold" BorderThickness="0"
                            Click="BtnHistoria_Click"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Window>