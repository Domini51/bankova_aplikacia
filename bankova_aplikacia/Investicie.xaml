<UserControl x:Class="bankova_aplikacia.Investicie"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="30,20">

                <TextBlock x:Name="TxtZostatok"
                           Text="Dostupný zostatok: 0 €"
                           Margin="0,0,0,20"
                           FontSize="15"
                           Foreground="#888888"/>

                <!-- sporiaci -->
                <Border Padding="20"
                        Margin="0,0,0,16"
                        Background="White"
                        BorderBrush="#D0D0D0"
                        BorderThickness="1"
                        CornerRadius="10">
                    <StackPanel>
                        <TextBlock Text="Sporiaci účet (30% z príjmu)"
                                   Margin="0,0,0,8"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="#1A1A1A"/>
                        <TextBlock x:Name="TxtSporiaci"
                                   Text="Odporúčaná suma: 0 €"
                                   FontSize="16"
                                   Foreground="#555555"/>
                    </StackPanel>
                </Border>

                <!-- etf -->
                <Border Padding="20"
                        Margin="0,0,0,16"
                        Background="White"
                        BorderBrush="#D0D0D0"
                        BorderThickness="1"
                        CornerRadius="10">
                    <StackPanel>
                        <TextBlock Text="ETF"
                                   Margin="0,0,0,10"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="#1A1A1A"/>

                        <Border Padding="15"
                                Margin="0,0,0,10"
                                Background="#F5F5F5"
                                CornerRadius="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="160"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="S&amp;P 500 (SPY)" FontSize="15" FontWeight="SemiBold" Foreground="#1A1A1A"/>
                                    <TextBlock x:Name="TxtSPY" Text="Načítavam..." FontSize="13" Foreground="#888888"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="% zostatku" FontSize="11" Foreground="#888888" HorizontalAlignment="Center"/>
                                    <Slider x:Name="SliderSPY" Minimum="0" Maximum="100" Value="0" Width="150" ValueChanged="Slider_Changed"/>
                                    <TextBlock x:Name="TxtSPYPercent" Text="0%" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="#1A1A1A"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Padding="15"
                                Background="#F5F5F5"
                                CornerRadius="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="160"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="MSCI World (URTH)" FontSize="15" FontWeight="SemiBold" Foreground="#1A1A1A"/>
                                    <TextBlock x:Name="TxtURTH" Text="Načítavam..." FontSize="13" Foreground="#888888"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="% zostatku" FontSize="11" Foreground="#888888" HorizontalAlignment="Center"/>
                                    <Slider x:Name="SliderURTH" Minimum="0" Maximum="100" Value="0" Width="150" ValueChanged="Slider_Changed"/>
                                    <TextBlock x:Name="TxtURTHPercent" Text="0%" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="#1A1A1A"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- akcie -->
                <Border Padding="20"
                        Margin="0,0,0,16"
                        Background="White"
                        BorderBrush="#D0D0D0"
                        BorderThickness="1"
                        CornerRadius="10">
                    <StackPanel>
                        <TextBlock Text="Akcie"
                                   Margin="0,0,0,10"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="#1A1A1A"/>

                        <Border Padding="15" Margin="0,0,0,10" Background="#F5F5F5" CornerRadius="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="160"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Apple (AAPL)" FontSize="15" FontWeight="SemiBold" Foreground="#1A1A1A"/>
                                    <TextBlock x:Name="TxtAAPL" Text="Načítavam..." FontSize="13" Foreground="#888888"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="% zostatku" FontSize="11" Foreground="#888888" HorizontalAlignment="Center"/>
                                    <Slider x:Name="SliderAAPL" Minimum="0" Maximum="100" Value="0" Width="150" ValueChanged="Slider_Changed"/>
                                    <TextBlock x:Name="TxtAAPLPercent" Text="0%" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="#1A1A1A"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Padding="15" Margin="0,0,0,10" Background="#F5F5F5" CornerRadius="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="160"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Tesla (TSLA)" FontSize="15" FontWeight="SemiBold" Foreground="#1A1A1A"/>
                                    <TextBlock x:Name="TxtTSLA" Text="Načítavam..." FontSize="13" Foreground="#888888"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="% zostatku" FontSize="11" Foreground="#888888" HorizontalAlignment="Center"/>
                                    <Slider x:Name="SliderTSLA" Minimum="0" Maximum="100" Value="0" Width="150" ValueChanged="Slider_Changed"/>
                                    <TextBlock x:Name="TxtTSLAPercent" Text="0%" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="#1A1A1A"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Padding="15" Background="#F5F5F5" CornerRadius="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="160"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="NVIDIA (NVDA)" FontSize="15" FontWeight="SemiBold" Foreground="#1A1A1A"/>
                                    <TextBlock x:Name="TxtNVDA" Text="Načítavam..." FontSize="13" Foreground="#888888"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="% zostatku" FontSize="11" Foreground="#888888" HorizontalAlignment="Center"/>
                                    <Slider x:Name="SliderNVDA" Minimum="0" Maximum="100" Value="0" Width="150" ValueChanged="Slider_Changed"/>
                                    <TextBlock x:Name="TxtNVDAPercent" Text="0%" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="#1A1A1A"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- krypto -->
                <Border Padding="20"
                        Margin="0,0,0,16"
                        Background="White"
                        BorderBrush="#D0D0D0"
                        BorderThickness="1"
                        CornerRadius="10">
                    <StackPanel>
                        <TextBlock Text="Kryptomeny"
                                   Margin="0,0,0,10"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="#1A1A1A"/>

                        <Border Padding="15" Margin="0,0,0,10" Background="#F5F5F5" CornerRadius="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="160"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Bitcoin (BTC)" FontSize="15" FontWeight="SemiBold" Foreground="#1A1A1A"/>
                                    <TextBlock x:Name="TxtBTC" Text="Načítavam..." FontSize="13" Foreground="#888888"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="% zostatku" FontSize="11" Foreground="#888888" HorizontalAlignment="Center"/>
                                    <Slider x:Name="SliderBTC" Minimum="0" Maximum="100" Value="0" Width="150" ValueChanged="Slider_Changed"/>
                                    <TextBlock x:Name="TxtBTCPercent" Text="0%" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="#1A1A1A"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Padding="15" Background="#F5F5F5" CornerRadius="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="160"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Ethereum (ETH)" FontSize="15" FontWeight="SemiBold" Foreground="#1A1A1A"/>
                                    <TextBlock x:Name="TxtETH" Text="Načítavam..." FontSize="13" Foreground="#888888"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="% zostatku" FontSize="11" Foreground="#888888" HorizontalAlignment="Center"/>
                                    <Slider x:Name="SliderETH" Minimum="0" Maximum="100" Value="0" Width="150" ValueChanged="Slider_Changed"/>
                                    <TextBlock x:Name="TxtETHPercent" Text="0%" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="#1A1A1A"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- suhrn -->
                <Border Padding="20"
                        Margin="0,0,0,20"
                        Background="White"
                        BorderBrush="#D0D0D0"
                        BorderThickness="1"
                        CornerRadius="10">
                    <StackPanel>
                        <TextBlock Text="Súhrn investícií"
                                   Margin="0,0,0,15"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="#1A1A1A"/>
                        <TextBlock x:Name="TxtCelkovePercento"
                                   Text="Celkovo alokované: 0%"
                                   Margin="0,0,0,5"
                                   FontSize="15"
                                   Foreground="#555555"/>
                        <TextBlock x:Name="TxtCelkovaSuma"
                                   Text="Celková suma: 0 €"
                                   Margin="0,0,0,15"
                                   FontSize="15"
                                   Foreground="#555555"/>
                        <ProgressBar x:Name="ProgressInvest"
                                     Height="18"
                                     Minimum="0" Maximum="100"
                                     Value="0"
                                     Margin="0,0,0,15"
                                     Background="#E0E0E0"
                                     BorderThickness="0"/>
                        <Button Click="BtnPotvrdit_Click"
                                Content="Potvrdiť investície"
                                Height="44"
                                FontSize="15"
                                FontWeight="SemiBold"
                                Background="#1A1A1A"
                                Foreground="White"
                                BorderThickness="0"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- spinner -->
        <Grid x:Name="SpinnerOverlay"
              Background="#88F5F5F5"
              Visibility="Visible">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border Width="60" Height="60">
                    <Border.RenderTransform>
                        <RotateTransform x:Name="SpinnerRotate" CenterX="30" CenterY="30"/>
                    </Border.RenderTransform>
                    <Border.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetName="SpinnerRotate"
                                                     Storyboard.TargetProperty="Angle"
                                                     From="0" To="360"
                                                     Duration="0:0:0.8"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Border.Triggers>
                    <Ellipse Width="60" Height="60"
                             Stroke="#2E6DA4"
                             StrokeThickness="5"
                             StrokeDashArray="10 5"/>
                </Border>
                <TextBlock Text="Načítavam kurzy..."
                           Margin="0,12,0,0"
                           FontSize="14"
                           Foreground="#555555"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>

    </Grid>
</UserControl>