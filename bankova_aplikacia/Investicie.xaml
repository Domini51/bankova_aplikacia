<UserControl x:Class="bankova_aplikacia.Investicie"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:bankova_aplikacia">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="380"/>
        </Grid.ColumnDefinitions>

        <!-- ===== ĽAVÁ STRANA – investície ===== -->
        <Grid Grid.Column="0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="30,20">

                    <TextBlock x:Name="TxtZostatok"
                               Text="Dostupný zostatok: 0 €"
                               Margin="0,0,0,20"
                               FontSize="15"
                               Foreground="{DynamicResource SekundarnyText}"/>

                    <!-- ETF -->
                    <Border Padding="20" Margin="0,0,0,16"
                            Background="{DynamicResource PanelBg}"
                            BorderBrush="{DynamicResource PanelBorder}"
                            BorderThickness="1" CornerRadius="10">
                        <StackPanel>
                            <TextBlock Text="ETF" Margin="0,0,0,10"
                                       FontSize="18" FontWeight="SemiBold"
                                       Foreground="{DynamicResource HlavnyText}"/>
                            <Border Padding="15" Margin="0,0,0,10"
                                    Background="{DynamicResource PolozkaBg}" CornerRadius="8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="160"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="S&amp;P 500 (SPY)" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource HlavnyText}"/>
                                        <TextBlock x:Name="TxtSPY" Text="Načítavam..." FontSize="13" Foreground="{DynamicResource SekundarnyText}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="% zostatku" FontSize="11" Foreground="{DynamicResource SekundarnyText}" HorizontalAlignment="Center"/>
                                        <Slider x:Name="SliderSPY" Minimum="0" Maximum="100" Value="0" Width="150" ValueChanged="Slider_Changed"/>
                                        <TextBlock x:Name="TxtSPYPercent" Text="0%" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="{DynamicResource HlavnyText}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <Border Padding="15" Background="{DynamicResource PolozkaBg}" CornerRadius="8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="160"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="MSCI World (URTH)" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource HlavnyText}"/>
                                        <TextBlock x:Name="TxtURTH" Text="Načítavam..." FontSize="13" Foreground="{DynamicResource SekundarnyText}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="% zostatku" FontSize="11" Foreground="{DynamicResource SekundarnyText}" HorizontalAlignment="Center"/>
                                        <Slider x:Name="SliderURTH" Minimum="0" Maximum="100" Value="0" Width="150" ValueChanged="Slider_Changed"/>
                                        <TextBlock x:Name="TxtURTHPercent" Text="0%" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="{DynamicResource HlavnyText}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Akcie -->
                    <Border Padding="20" Margin="0,0,0,16"
                            Background="{DynamicResource PanelBg}"
                            BorderBrush="{DynamicResource PanelBorder}"
                            BorderThickness="1" CornerRadius="10">
                        <StackPanel>
                            <TextBlock Text="Akcie" Margin="0,0,0,10"
                                       FontSize="18" FontWeight="SemiBold"
                                       Foreground="{DynamicResource HlavnyText}"/>
                            <Border Padding="15" Margin="0,0,0,10" Background="{DynamicResource PolozkaBg}" CornerRadius="8">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="160"/></Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Apple (AAPL)" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource HlavnyText}"/>
                                        <TextBlock x:Name="TxtAAPL" Text="Načítavam..." FontSize="13" Foreground="{DynamicResource SekundarnyText}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="% zostatku" FontSize="11" Foreground="{DynamicResource SekundarnyText}" HorizontalAlignment="Center"/>
                                        <Slider x:Name="SliderAAPL" Minimum="0" Maximum="100" Value="0" Width="150" ValueChanged="Slider_Changed"/>
                                        <TextBlock x:Name="TxtAAPLPercent" Text="0%" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="{DynamicResource HlavnyText}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <Border Padding="15" Margin="0,0,0,10" Background="{DynamicResource PolozkaBg}" CornerRadius="8">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="160"/></Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Tesla (TSLA)" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource HlavnyText}"/>
                                        <TextBlock x:Name="TxtTSLA" Text="Načítavam..." FontSize="13" Foreground="{DynamicResource SekundarnyText}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="% zostatku" FontSize="11" Foreground="{DynamicResource SekundarnyText}" HorizontalAlignment="Center"/>
                                        <Slider x:Name="SliderTSLA" Minimum="0" Maximum="100" Value="0" Width="150" ValueChanged="Slider_Changed"/>
                                        <TextBlock x:Name="TxtTSLAPercent" Text="0%" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="{DynamicResource HlavnyText}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <Border Padding="15" Background="{DynamicResource PolozkaBg}" CornerRadius="8">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="160"/></Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="NVIDIA (NVDA)" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource HlavnyText}"/>
                                        <TextBlock x:Name="TxtNVDA" Text="Načítavam..." FontSize="13" Foreground="{DynamicResource SekundarnyText}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="% zostatku" FontSize="11" Foreground="{DynamicResource SekundarnyText}" HorizontalAlignment="Center"/>
                                        <Slider x:Name="SliderNVDA" Minimum="0" Maximum="100" Value="0" Width="150" ValueChanged="Slider_Changed"/>
                                        <TextBlock x:Name="TxtNVDAPercent" Text="0%" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="{DynamicResource HlavnyText}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Kryptomeny -->
                    <Border Padding="20" Margin="0,0,0,16"
                            Background="{DynamicResource PanelBg}"
                            BorderBrush="{DynamicResource PanelBorder}"
                            BorderThickness="1" CornerRadius="10">
                        <StackPanel>
                            <TextBlock Text="Kryptomeny" Margin="0,0,0,10"
                                       FontSize="18" FontWeight="SemiBold"
                                       Foreground="{DynamicResource HlavnyText}"/>
                            <Border Padding="15" Margin="0,0,0,10" Background="{DynamicResource PolozkaBg}" CornerRadius="8">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="160"/></Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Bitcoin (BTC)" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource HlavnyText}"/>
                                        <TextBlock x:Name="TxtBTC" Text="Načítavam..." FontSize="13" Foreground="{DynamicResource SekundarnyText}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="% zostatku" FontSize="11" Foreground="{DynamicResource SekundarnyText}" HorizontalAlignment="Center"/>
                                        <Slider x:Name="SliderBTC" Minimum="0" Maximum="100" Value="0" Width="150" ValueChanged="Slider_Changed"/>
                                        <TextBlock x:Name="TxtBTCPercent" Text="0%" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="{DynamicResource HlavnyText}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <Border Padding="15" Background="{DynamicResource PolozkaBg}" CornerRadius="8">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="160"/></Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Ethereum (ETH)" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource HlavnyText}"/>
                                        <TextBlock x:Name="TxtETH" Text="Načítavam..." FontSize="13" Foreground="{DynamicResource SekundarnyText}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="% zostatku" FontSize="11" Foreground="{DynamicResource SekundarnyText}" HorizontalAlignment="Center"/>
                                        <Slider x:Name="SliderETH" Minimum="0" Maximum="100" Value="0" Width="150" ValueChanged="Slider_Changed"/>
                                        <TextBlock x:Name="TxtETHPercent" Text="0%" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="{DynamicResource HlavnyText}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Súhrn -->
                    <Border Padding="20" Margin="0,0,0,20"
                            Background="{DynamicResource PanelBg}"
                            BorderBrush="{DynamicResource PanelBorder}"
                            BorderThickness="1" CornerRadius="10">
                        <StackPanel>
                            <TextBlock Text="Súhrn investícií" Margin="0,0,0,15"
                                       FontSize="18" FontWeight="SemiBold"
                                       Foreground="{DynamicResource HlavnyText}"/>
                            <TextBlock x:Name="TxtCelkovePercento" Text="Celkovo alokované: 0%"
                                       Margin="0,0,0,5" FontSize="15" Foreground="{DynamicResource StrednyText}"/>
                            <TextBlock x:Name="TxtCelkovaSuma" Text="Celková suma: 0 €"
                                       Margin="0,0,0,5" FontSize="15" Foreground="{DynamicResource StrednyText}"/>
                            <TextBlock x:Name="TxtZostokPo" Text="Zostatok po investovaní: 0 €"
                                       Margin="0,0,0,15" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{DynamicResource StrednyText}"/>
                            <ProgressBar x:Name="ProgressInvest" Height="18"
                                         Minimum="0" Maximum="100" Value="0"
                                         Margin="0,0,0,15"
                                         Background="{DynamicResource Oddelovac}"
                                         BorderThickness="0"/>
                            <Button Click="BtnPotvrdit_Click"
                                    Content="Potvrdiť investície"
                                    Height="44" FontSize="15" FontWeight="SemiBold"
                                    Background="#1A1A1A" Foreground="White" BorderThickness="0"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- spinner -->
            <Grid x:Name="SpinnerOverlay"
                  Background="{DynamicResource SpinnerBg}"
                  Visibility="Collapsed">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Border Width="60" Height="60">
                        <Border.RenderTransform>
                            <RotateTransform x:Name="SpinnerRotate" CenterX="30" CenterY="30"/>
                        </Border.RenderTransform>
                        <Border.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation Storyboard.TargetName="SpinnerRotate"
                                                         Storyboard.TargetProperty="Angle"
                                                         From="0" To="360" Duration="0:0:0.8"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Border.Triggers>
                        <Ellipse Width="60" Height="60" Stroke="#1A1A1A"
                                 StrokeThickness="5" StrokeDashArray="10 5"/>
                    </Border>
                    <TextBlock Text="Načítavam kurzy..." Margin="0,12,0,0"
                               FontSize="14" Foreground="{DynamicResource StrednyText}"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- ===== PRAVÁ STRANA – AI chat ===== -->
        <Border Grid.Column="1"
                BorderBrush="{DynamicResource PanelBorder}"
                BorderThickness="1,0,0,0">
            <local:Asistent x:Name="ChatPanel"/>
        </Border>

    </Grid>
</UserControl>
