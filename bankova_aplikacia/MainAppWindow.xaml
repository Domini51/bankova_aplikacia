<Window x:Class="bankova_aplikacia.MainAppWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:bankova_aplikacia"
        WindowState="Maximized"
        Title="Investičná Banka" Height="900" Width="1200"
        Background="#F5F5F5">

    <Window.Resources>
        <!-- pulse animacia pre tlacidla v sidebari -->
        <Storyboard x:Key="PulseAnimacia">
            <DoubleAnimationUsingKeyFrames
                Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)">
                <EasingDoubleKeyFrame KeyTime="0:0:0.0" Value="1"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.1" Value="0.92"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="1"/>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames
                Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)">
                <EasingDoubleKeyFrame KeyTime="0:0:0.0" Value="1"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.1" Value="0.92"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="1"/>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="255"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <!-- ===== SIDEBAR ===== -->
        <Grid Grid.Column="0" Background="#1A1A1A">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="20,20,20,16">
                <Image Source="/Assets/investicna_banka_logo-1-removebg-preview.png.png"
                       Height="79" HorizontalAlignment="Left"
                       RenderOptions.BitmapScalingMode="HighQuality" Width="215"/>
                <Border Height="1" Background="#333333" Margin="0,16,0,0"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Margin="0,8,0,0">
                <Button x:Name="BtnPrehlad"
                        Content="  Výpočet výdavkov"
                        Height="50" HorizontalContentAlignment="Left"
                        Background="#2A2A2A" Foreground="White"
                        BorderThickness="3,0,0,0" BorderBrush="White"
                        FontSize="19" Padding="17,0,0,0"
                        RenderTransformOrigin="0.5,0.5"
                        Click="BtnPrehlad_Click">
                    <Button.RenderTransform>
                        <ScaleTransform/>
                    </Button.RenderTransform>
                </Button>
                <Button x:Name="BtnHistoria"
                        Content="  História"
                        Height="50" HorizontalContentAlignment="Left"
                        Background="Transparent" Foreground="#AAAAAA"
                        BorderThickness="0" FontSize="19" Padding="20,0,0,0"
                        RenderTransformOrigin="0.5,0.5"
                        Click="BtnHistoria_Click">
                    <Button.RenderTransform>
                        <ScaleTransform/>
                    </Button.RenderTransform>
                </Button>
                <Button x:Name="BtnInvesticie"
                        Content="  Investície"
                        Height="50" HorizontalContentAlignment="Left"
                        Background="Transparent" Foreground="#AAAAAA"
                        BorderThickness="0" FontSize="19" Padding="20,0,0,0"
                        RenderTransformOrigin="0.5,0.5"
                        Click="BtnInvesticie_Click">
                    <Button.RenderTransform>
                        <ScaleTransform/>
                    </Button.RenderTransform>
                </Button>
                <Button x:Name="BtnUcet"
                        Content="  Účet"
                        Height="50" HorizontalContentAlignment="Left"
                        Background="Transparent" Foreground="#AAAAAA"
                        BorderThickness="0" FontSize="19" Padding="20,0,0,0"
                        RenderTransformOrigin="0.5,0.5"
                        Click="BtnUcet_Click">
                    <Button.RenderTransform>
                        <ScaleTransform/>
                    </Button.RenderTransform>
                </Button>
            </StackPanel>

            <StackPanel Grid.Row="2" Margin="0,0,0,10">
                <Border Height="1" Background="#333333" Margin="20,0,20,8"/>
                <Button x:Name="BtnNastavenia"
                        Content="  Nastavenia"
                        Height="50" HorizontalContentAlignment="Left"
                        Background="Transparent" Foreground="#AAAAAA"
                        BorderThickness="0" FontSize="19" Padding="20,0,0,0"
                        RenderTransformOrigin="0.5,0.5"
                        Click="BtnNastavenia_Click">
                    <Button.RenderTransform>
                        <ScaleTransform/>
                    </Button.RenderTransform>
                </Button>
                <Button x:Name="BtnOdhlasit"
                        Content="  Odhlásiť sa"
                        Height="50" HorizontalContentAlignment="Left"
                        Background="Transparent" Foreground="#E24B4A"
                        BorderThickness="0" FontSize="19" Padding="20,0,0,0"
                        Click="BtnOdhlasit_Click"/>
            </StackPanel>
        </Grid>

        <!-- ===== OBSAH ===== -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- topbar -->
            <Border Grid.Row="0" Background="White"
                    BorderBrush="#D0D0D0" BorderThickness="0,0,0,1" Margin="0,-1,5,1">
                <Grid Margin="30,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="TopbarTitle"
                               Grid.Column="0" Text=""
                               FontSize="20" FontWeight="SemiBold"
                               Foreground="#1A1A1A" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TopbarVitaj"
                               Grid.Column="1" Text=""
                               FontSize="15" Foreground="Black"
                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                </Grid>
            </Border>

            <!-- ===== PANELY ===== -->
            <local:VypocetVydavkou x:Name="PanelPrehlad" Grid.Row="1" Visibility="Visible"/>
            <local:Historia x:Name="PanelHistoria" Grid.Row="1" Visibility="Hidden"/>
            <local:Investicie x:Name="PanelInvesticie" Grid.Row="1" Visibility="Hidden"/>
            <local:Ucet x:Name="PanelUcet" Grid.Row="1" Visibility="Hidden"/>
            <local:Nastavenia x:Name="PanelNastavenia" Grid.Row="1" Visibility="Hidden"/>

        </Grid>
    </Grid>
</Window>