<Window x:Class="bankova_aplikacia.MainAppWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:bankova_aplikacia"
        Title="Investičná Banka"
        Height="900" Width="1200"
        WindowState="Maximized"
        Background="{DynamicResource HlavnyBg}">

    <Window.Resources>
        <Storyboard x:Key="PulseAnimacia">
            <DoubleAnimationUsingKeyFrames
                Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)">
                <EasingDoubleKeyFrame Value="1"    KeyTime="0:0:0.0"/>
                <EasingDoubleKeyFrame Value="0.93" KeyTime="0:0:0.1"/>
                <EasingDoubleKeyFrame Value="1"    KeyTime="0:0:0.2"/>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames
                Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)">
                <EasingDoubleKeyFrame Value="1"    KeyTime="0:0:0.0"/>
                <EasingDoubleKeyFrame Value="0.93" KeyTime="0:0:0.1"/>
                <EasingDoubleKeyFrame Value="1"    KeyTime="0:0:0.2"/>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>

        <!-- Štýl pre nav položky -->
        <Style x:Key="NavItem" TargetType="Button" BasedOn="{StaticResource NavButton}">
            <Setter Property="Height" Value="50"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="20,0,0,0"/>
            <Setter Property="Foreground" Value="#777777"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ===== SIDEBAR ===== -->
        <Grid Grid.Column="0" Background="#0F0F0F">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Brand -->
            <StackPanel Grid.Row="0" Margin="20,24,20,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="36" Height="36" CornerRadius="10" Background="White" Margin="0,0,12,0">
                        <TextBlock Text="IB"
                                   FontSize="14" FontWeight="Bold"
                                   Foreground="#111111"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Investičná"
                                   FontSize="14" FontWeight="Bold"
                                   Foreground="White"/>
                        <TextBlock Text="Banka"
                                   FontSize="14" FontWeight="Bold"
                                   Foreground="White" Margin="0,-2,0,0"/>
                    </StackPanel>
                </StackPanel>
                <Border Height="1" Background="#1C1C1C" Margin="0,20,0,0"/>
            </StackPanel>

            <!-- Sekcia: HLAVNÉ -->
            <StackPanel Grid.Row="1" Margin="0,8,0,0">
                <TextBlock Text="HLAVNÉ"
                           FontSize="10" FontWeight="SemiBold"
                           Foreground="#3A3A3A"
                           Margin="22,12,0,6"/>

                <Button x:Name="BtnPrehlad"
                        Style="{StaticResource NavItem}"
                        Click="BtnPrehlad_Click"
                        Background="#1A1A1A"
                        Foreground="White"
                        BorderThickness="3,0,0,0"
                        BorderBrush="#FFFFFF">
                    <TextBlock Text="Výpočet výdavkov" VerticalAlignment="Center"/>
                    <Button.RenderTransform><ScaleTransform/></Button.RenderTransform>
                </Button>

                <Button x:Name="BtnInvesticie"
                        Style="{StaticResource NavItem}"
                        Click="BtnInvesticie_Click">
                    <TextBlock Text="Investície" VerticalAlignment="Center"/>
                    <Button.RenderTransform><ScaleTransform/></Button.RenderTransform>
                </Button>

                <Button x:Name="BtnUcet"
                        Style="{StaticResource NavItem}"
                        Click="BtnUcet_Click">
                    <TextBlock Text="Účet" VerticalAlignment="Center"/>
                    <Button.RenderTransform><ScaleTransform/></Button.RenderTransform>
                </Button>

                <Button x:Name="BtnHistoria"
                        Style="{StaticResource NavItem}"
                        Click="BtnHistoria_Click">
                    <TextBlock Text="História" VerticalAlignment="Center"/>
                    <Button.RenderTransform><ScaleTransform/></Button.RenderTransform>
                </Button>

            </StackPanel>

            <!-- Bottom -->
            <StackPanel Grid.Row="2" Margin="0,0,0,16">
                <Border Height="1" Background="#1C1C1C" Margin="20,0,20,8"/>

                <Button x:Name="BtnNastavenia"
                        Style="{StaticResource NavItem}"
                        Click="BtnNastavenia_Click">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="16" Width="28" VerticalAlignment="Center"/>
                        <TextBlock Text="Nastavenia" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button.RenderTransform><ScaleTransform/></Button.RenderTransform>
                </Button>

                <Button x:Name="BtnTema"
                        Style="{StaticResource NavButton}"
                        Click="BtnTema_Click"
                        Height="44"
                        Padding="20,0,0,0"
                        Foreground="#555555">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock x:Name="IkonaTema"
                                   Text="&#xE708;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="16" Width="28"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="Prepnúť tému" FontSize="13" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button x:Name="BtnOdhlasit"
                        Style="{StaticResource NavButton}"
                        Click="BtnOdhlasit_Click"
                        Height="46"
                        Padding="20,0,0,0"
                        Foreground="#C0392B">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#xE7E8;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="16" Width="28" VerticalAlignment="Center"/>
                        <TextBlock Text="Odhlásiť sa" FontSize="14" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

            </StackPanel>
        </Grid>

        <!-- ===== HLAVNÝ OBSAH ===== -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="62"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Topbar -->
            <Border Grid.Row="0"
                    Background="{DynamicResource TopbarBg}"
                    BorderBrush="{DynamicResource TopbarBorder}"
                    BorderThickness="0,0,0,1">
                <Grid Margin="30,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="TopbarTitle"
                               Grid.Column="0"
                               Text=""
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource HlavnyText}"
                               VerticalAlignment="Center"/>

                    <!-- User chip -->
                    <Border Grid.Column="1"
                            Background="{DynamicResource PolozkaBg}"
                            CornerRadius="20"
                            Padding="12,6">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="26" Height="26" CornerRadius="13"
                                    Background="#111111" Margin="0,0,8,0">
                                <TextBlock Text="&#xE77B;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="13"
                                           Foreground="White"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock x:Name="TopbarVitaj"
                                       Text=""
                                       FontSize="13"
                                       Foreground="{DynamicResource HlavnyText}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <local:VypocetVydavkou x:Name="PanelPrehlad"   Grid.Row="1" Visibility="Visible"/>
            <local:Historia        x:Name="PanelHistoria"   Grid.Row="1" Visibility="Collapsed"/>
            <local:Investicie      x:Name="PanelInvesticie" Grid.Row="1" Visibility="Collapsed"/>
            <local:Ucet            x:Name="PanelUcet"       Grid.Row="1" Visibility="Collapsed"/>
            <local:Nastavenia      x:Name="PanelNastavenia" Grid.Row="1" Visibility="Collapsed"/>

        </Grid>
    </Grid>
</Window>
