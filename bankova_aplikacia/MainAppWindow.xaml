<Window x:Class="bankova_aplikacia.MainAppWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:bankova_aplikacia"
        WindowState="Maximized"
        Title="Investičná Banka" Height="900" Width="1200"
        Background="#F5F5F7">

    <Window.Resources>
        <Storyboard x:Key="PulseAnimacia">
            <DoubleAnimationUsingKeyFrames
                Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)">
                <EasingDoubleKeyFrame KeyTime="0:0:0.0" Value="1"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.1" Value="0.92"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="1"/>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames
                Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)">
                <EasingDoubleKeyFrame KeyTime="0:0:0.0" Value="1"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.1" Value="0.92"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="1"/>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ===== SIDEBAR ===== -->
        <Grid Grid.Column="0" Background="#111111">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="18,20,18,16">
                <Image Source="/Assets/investicna_banka_logo-1-removebg-preview.png.png"
                       Height="60" HorizontalAlignment="Left"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
                <Border Height="1" Background="#222222" Margin="0,14,0,0"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Margin="0,8,0,0">
                <Button x:Name="BtnPrehlad"
                        Height="46" HorizontalContentAlignment="Left"
                        Background="#2A2A2A" Foreground="White"
                        BorderThickness="3,0,0,0" BorderBrush="White"
                        FontSize="13" Padding="17,0,0,0"
                        RenderTransformOrigin="0.5,0.5"
                        Click="BtnPrehlad_Click">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="⬡" FontSize="13" Foreground="White"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Výpočet výdavkov" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button.RenderTransform>
                        <ScaleTransform/>
                    </Button.RenderTransform>
                </Button>

                <Button x:Name="BtnHistoria"
                        Height="46" HorizontalContentAlignment="Left"
                        Background="Transparent" Foreground="#666666"
                        BorderThickness="0" FontSize="13" Padding="20,0,0,0"
                        RenderTransformOrigin="0.5,0.5"
                        Click="BtnHistoria_Click">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="⬡" FontSize="13" Foreground="#333333"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="História" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button.RenderTransform>
                        <ScaleTransform/>
                    </Button.RenderTransform>
                </Button>

                <Button x:Name="BtnInvesticie"
                        Height="46" HorizontalContentAlignment="Left"
                        Background="Transparent" Foreground="#666666"
                        BorderThickness="0" FontSize="13" Padding="20,0,0,0"
                        RenderTransformOrigin="0.5,0.5"
                        Click="BtnInvesticie_Click">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="⬡" FontSize="13" Foreground="#333333"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Investície" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button.RenderTransform>
                        <ScaleTransform/>
                    </Button.RenderTransform>
                </Button>

                <Button x:Name="BtnUcet"
                        Height="46" HorizontalContentAlignment="Left"
                        Background="Transparent" Foreground="#666666"
                        BorderThickness="0" FontSize="13" Padding="20,0,0,0"
                        RenderTransformOrigin="0.5,0.5"
                        Click="BtnUcet_Click">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="⬡" FontSize="13" Foreground="#333333"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Účet" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button.RenderTransform>
                        <ScaleTransform/>
                    </Button.RenderTransform>
                </Button>
            </StackPanel>

            <StackPanel Grid.Row="2" Margin="0,0,0,12">
                <Border Height="1" Background="#222222" Margin="18,0,18,8"/>
                <Button x:Name="BtnNastavenia"
                        Height="46" HorizontalContentAlignment="Left"
                        Background="Transparent" Foreground="#666666"
                        BorderThickness="0" FontSize="13" Padding="20,0,0,0"
                        RenderTransformOrigin="0.5,0.5"
                        Click="BtnNastavenia_Click">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="⬡" FontSize="13" Foreground="#333333"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Nastavenia" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button.RenderTransform>
                        <ScaleTransform/>
                    </Button.RenderTransform>
                </Button>
                <Button x:Name="BtnOdhlasit"
                        Height="46" HorizontalContentAlignment="Left"
                        Background="Transparent" Foreground="#E24B4A"
                        BorderThickness="0" FontSize="13" Padding="20,0,0,0"
                        Click="BtnOdhlasit_Click">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="⬡" FontSize="13" Foreground="#6B2020"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Odhlásiť sa" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- ===== OBSAH ===== -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="White"
                    BorderBrush="#E8E8E8" BorderThickness="0,0,0,1">
                <Grid Margin="30,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="3" Height="18" Background="#1A1A1A"
                                CornerRadius="2" Margin="0,0,10,0"/>
                        <TextBlock x:Name="TopbarTitle" Text=""
                                   FontSize="18" FontWeight="SemiBold"
                                   Foreground="#1A1A1A" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Border Grid.Column="1" Background="#F0F0F0" CornerRadius="20"
                            Padding="14,6" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="7" Height="7" Fill="#1A1A1A"
                                     VerticalAlignment="Center" Margin="0,0,7,0"/>
                            <TextBlock x:Name="TopbarVitaj" Text=""
                                       FontSize="13" Foreground="#1A1A1A"
                                       FontWeight="Medium" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <local:VypocetVydavkou x:Name="PanelPrehlad"   Grid.Row="1" Visibility="Visible"/>
            <local:Historia        x:Name="PanelHistoria"   Grid.Row="1" Visibility="Hidden"/>
            <local:Investicie      x:Name="PanelInvesticie" Grid.Row="1" Visibility="Hidden"/>
            <local:Ucet            x:Name="PanelUcet"       Grid.Row="1" Visibility="Hidden"/>
            <local:Nastavenia      x:Name="PanelNastavenia" Grid.Row="1" Visibility="Hidden"/>
        </Grid>
    </Grid>
</Window>