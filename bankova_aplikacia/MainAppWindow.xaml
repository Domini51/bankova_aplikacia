<Window x:Class="bankova_aplikacia.MainAppWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:bankova_aplikacia"
        Title="Investičná Banka"
        Height="900" Width="1200"
        WindowState="Maximized"
        Background="{DynamicResource HlavnyBg}">

    <Window.Resources>
        <Storyboard x:Key="PulseAnimacia">
            <DoubleAnimationUsingKeyFrames
                Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)">
                <EasingDoubleKeyFrame Value="1" KeyTime="0:0:0.0"/>
                <EasingDoubleKeyFrame Value="0.92" KeyTime="0:0:0.1"/>
                <EasingDoubleKeyFrame Value="1" KeyTime="0:0:0.2"/>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames
                Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)">
                <EasingDoubleKeyFrame Value="1" KeyTime="0:0:0.0"/>
                <EasingDoubleKeyFrame Value="0.92" KeyTime="0:0:0.1"/>
                <EasingDoubleKeyFrame Value="1" KeyTime="0:0:0.2"/>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="265"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- sidebar -->
        <Grid Grid.Column="0" Background="#111111">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="18,20,18,16">
                <Image Height="60"
                       HorizontalAlignment="Left"
                       Source="/Assets/investicna_banka_logo-1-removebg-preview.png.png"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
                <Border Height="1" Background="#222222" Margin="0,14,0,0"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Margin="0,8,0,0">

                <Button x:Name="BtnPrehlad"
                        Click="BtnPrehlad_Click"
                        Height="50"
                        FontSize="19"
                        Padding="17,0,0,0"
                        HorizontalContentAlignment="Left"
                        Background="#2A2A2A"
                        Foreground="White"
                        BorderThickness="3,0,0,0"
                        BorderBrush="White"
                        RenderTransformOrigin="0.5,0.5">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Výpočet výdavkov" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button.RenderTransform>
                        <ScaleTransform/>
                    </Button.RenderTransform>
                </Button>

                <Button x:Name="BtnHistoria"
                        Click="BtnHistoria_Click"
                        Height="50"
                        FontSize="19"
                        Padding="20,0,0,0"
                        HorizontalContentAlignment="Left"
                        Background="Transparent"
                        Foreground="#666666"
                        BorderThickness="0"
                        RenderTransformOrigin="0.5,0.5">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="História" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button.RenderTransform>
                        <ScaleTransform/>
                    </Button.RenderTransform>
                </Button>

                <Button x:Name="BtnInvesticie"
                        Click="BtnInvesticie_Click"
                        Height="50"
                        FontSize="19"
                        Padding="20,0,0,0"
                        HorizontalContentAlignment="Left"
                        Background="Transparent"
                        Foreground="#666666"
                        BorderThickness="0"
                        RenderTransformOrigin="0.5,0.5">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Investície" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button.RenderTransform>
                        <ScaleTransform/>
                    </Button.RenderTransform>
                </Button>

                <Button x:Name="BtnUcet"
                        Click="BtnUcet_Click"
                        Height="50"
                        FontSize="19"
                        Padding="20,0,0,0"
                        HorizontalContentAlignment="Left"
                        Background="Transparent"
                        Foreground="#666666"
                        BorderThickness="0"
                        RenderTransformOrigin="0.5,0.5">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Účet" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button.RenderTransform>
                        <ScaleTransform/>
                    </Button.RenderTransform>
                </Button>

            </StackPanel>

            <StackPanel Grid.Row="2" Margin="0,0,0,12">
                <Border Height="1" Background="#222222" Margin="18,0,18,8"/>

                <Button x:Name="BtnTema"
                        Click="BtnTema_Click"
                        Height="44"
                        Padding="18,0,0,0"
                        HorizontalContentAlignment="Left"
                        Background="Transparent"
                        Foreground="#666666"
                        BorderThickness="0"
                        ToolTip="Prepnúť tému">
                    <TextBlock x:Name="IkonaTema"
                               Text="🌙"
                               FontSize="22"
                               FontFamily="Segoe UI Emoji"
                               VerticalAlignment="Center"/>
                </Button>

                <Button x:Name="BtnNastavenia"
                        Click="BtnNastavenia_Click"
                        Height="50"
                        FontSize="19"
                        Padding="20,0,0,0"
                        HorizontalContentAlignment="Left"
                        Background="Transparent"
                        Foreground="#666666"
                        BorderThickness="0"
                        RenderTransformOrigin="0.5,0.5">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Nastavenia" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button.RenderTransform>
                        <ScaleTransform/>
                    </Button.RenderTransform>
                </Button>

                <Button x:Name="BtnOdhlasit"
                       
                        Height="50"
                        FontSize="19"
                        Padding="20,0,0,0"
                        HorizontalContentAlignment="Left"
                        Background="Transparent"
                        Foreground="#E24B4A"
                        BorderThickness="0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Odhlásiť sa" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

            </StackPanel>
        </Grid>

        <!-- obsah -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{DynamicResource TopbarBg}"
                    BorderBrush="{DynamicResource TopbarBorder}"
                    BorderThickness="0,0,0,1">
                <Grid Margin="30,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Border Width="3" Height="18"
                                Background="#1A1A1A"
                                CornerRadius="2"
                                Margin="0,0,10,0"/>
                        <TextBlock x:Name="TopbarTitle"
                                   Text=""
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource HlavnyText}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <Border Grid.Column="1"
                            Background="{DynamicResource PolozkaBg}"
                            CornerRadius="20"
                            Padding="14,6"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="7" Height="7"
                                     Fill="{DynamicResource HlavnyText}"
                                     VerticalAlignment="Center"
                                     Margin="0,0,7,0"/>
                            <TextBlock x:Name="TopbarVitaj"
                                       Text=""
                                       FontSize="13"
                                       Foreground="{DynamicResource HlavnyText}"
                                       FontWeight="Medium"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <local:VypocetVydavkou x:Name="PanelPrehlad" Grid.Row="1" Visibility="Visible"/>
            <local:Historia x:Name="PanelHistoria" Grid.Row="1" Visibility="Hidden"/>
            <local:Investicie x:Name="PanelInvesticie" Grid.Row="1" Visibility="Hidden"/>
            <local:Ucet x:Name="PanelUcet" Grid.Row="1" Visibility="Hidden"/>
            <local:Nastavenia x:Name="PanelNastavenia" Grid.Row="1" Visibility="Hidden"/>

        </Grid>
    </Grid>
</Window>