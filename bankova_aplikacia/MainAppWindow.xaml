<Window x:Class="bankova_aplikacia.MainAppWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:bankova_aplikacia"
        Title="Investičná Banka"
        Height="900" Width="1200"
        WindowState="Maximized"
        Background="{DynamicResource HlavnyBg}">

    <Window.Resources>
        <Storyboard x:Key="PulseAnimacia">
            <DoubleAnimationUsingKeyFrames
                Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)">
                <EasingDoubleKeyFrame Value="1" KeyTime="0:0:0.0"/>
                <EasingDoubleKeyFrame Value="0.93" KeyTime="0:0:0.1"/>
                <EasingDoubleKeyFrame Value="1" KeyTime="0:0:0.2"/>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames
                Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)">
                <EasingDoubleKeyFrame Value="1" KeyTime="0:0:0.0"/>
                <EasingDoubleKeyFrame Value="0.93" KeyTime="0:0:0.1"/>
                <EasingDoubleKeyFrame Value="1" KeyTime="0:0:0.2"/>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- sidebar -->
        <Grid Grid.Column="0" Background="#111111">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- logo -->
            <StackPanel Grid.Row="0" Margin="18,22,18,16">
                <Image Height="54"
                       HorizontalAlignment="Left"
                       Source="/Assets/investicna_banka_logo-1-removebg-preview.png.png"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
                <Border Height="1" Background="#1E1E1E" Margin="0,16,0,0"/>
            </StackPanel>

            <!-- nav -->
            <StackPanel Grid.Row="1" Margin="0,6,0,0">

                <Button x:Name="BtnPrehlad"
                        Style="{StaticResource NavButton}"
                        Click="BtnPrehlad_Click"
                        Height="48"
                        FontSize="15"
                        Padding="20,0,0,0"
                        Background="#1E1E1E"
                        Foreground="White"
                        BorderThickness="3,0,0,0"
                        BorderBrush="#2E6DA4"
                        RenderTransformOrigin="0.5,0.5">
                    <TextBlock Text="Výpočet výdavkov" VerticalAlignment="Center"/>
                    <Button.RenderTransform><ScaleTransform/></Button.RenderTransform>
                </Button>

                <Button x:Name="BtnHistoria"
                        Style="{StaticResource NavButton}"
                        Click="BtnHistoria_Click"
                        Height="48"
                        FontSize="15"
                        Padding="20,0,0,0"
                        Foreground="#888888"
                        RenderTransformOrigin="0.5,0.5">
                    <TextBlock Text="História" VerticalAlignment="Center"/>
                    <Button.RenderTransform><ScaleTransform/></Button.RenderTransform>
                </Button>

                <Button x:Name="BtnInvesticie"
                        Style="{StaticResource NavButton}"
                        Click="BtnInvesticie_Click"
                        Height="48"
                        FontSize="15"
                        Padding="20,0,0,0"
                        Foreground="#888888"
                        RenderTransformOrigin="0.5,0.5">
                    <TextBlock Text="Investície" VerticalAlignment="Center"/>
                    <Button.RenderTransform><ScaleTransform/></Button.RenderTransform>
                </Button>

                <Button x:Name="BtnUcet"
                        Style="{StaticResource NavButton}"
                        Click="BtnUcet_Click"
                        Height="48"
                        FontSize="15"
                        Padding="20,0,0,0"
                        Foreground="#888888"
                        RenderTransformOrigin="0.5,0.5">
                    <TextBlock Text="Účet" VerticalAlignment="Center"/>
                    <Button.RenderTransform><ScaleTransform/></Button.RenderTransform>
                </Button>

            </StackPanel>

            <!-- bottom -->
            <StackPanel Grid.Row="2" Margin="0,0,0,12">
                <Border Height="1" Background="#1E1E1E" Margin="18,0,18,6"/>

                <Button x:Name="BtnTema"
                        Style="{StaticResource NavButton}"
                        Click="BtnTema_Click"
                        Height="42"
                        Padding="18,0,0,0"
                        Foreground="#666666"
                        ToolTip="Prepnúť tému">
                    <TextBlock x:Name="IkonaTema"
                               Text="🌙"
                               FontSize="20"
                               FontFamily="Segoe UI Emoji"
                               VerticalAlignment="Center"/>
                </Button>

                <Button x:Name="BtnNastavenia"
                        Style="{StaticResource NavButton}"
                        Click="BtnNastavenia_Click"
                        Height="48"
                        FontSize="15"
                        Padding="20,0,0,0"
                        Foreground="#888888"
                        RenderTransformOrigin="0.5,0.5">
                    <TextBlock Text="Nastavenia" VerticalAlignment="Center"/>
                    <Button.RenderTransform><ScaleTransform/></Button.RenderTransform>
                </Button>

                <Button x:Name="BtnOdhlasit"
                        Style="{StaticResource NavButton}"
                        Click="BtnOdhlasit_Click"
                        Height="48"
                        FontSize="15"
                        Padding="20,0,0,0"
                        Foreground="#C0392B">
                    <TextBlock Text="Odhlásiť sa" VerticalAlignment="Center"/>
                </Button>

            </StackPanel>
        </Grid>

        <!-- content -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="58"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- topbar -->
            <Border Grid.Row="0"
                    Background="{DynamicResource TopbarBg}"
                    BorderBrush="{DynamicResource TopbarBorder}"
                    BorderThickness="0,0,0,1">
                <Grid Margin="28,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="3" Height="16"
                                Background="#1A1A1A"
                                CornerRadius="2"
                                Margin="0,0,10,0"/>
                        <TextBlock x:Name="TopbarTitle"
                                   Text=""
                                   FontSize="17"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource HlavnyText}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock Grid.Column="1"
                               x:Name="TopbarVitaj"
                               Text=""
                               FontSize="13"
                               Foreground="{DynamicResource SekundarnyText}"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <local:VypocetVydavkou x:Name="PanelPrehlad"  Grid.Row="1" Visibility="Visible"/>
            <local:Historia        x:Name="PanelHistoria"  Grid.Row="1" Visibility="Collapsed"/>
            <local:Investicie      x:Name="PanelInvesticie" Grid.Row="1" Visibility="Collapsed"/>
            <local:Ucet            x:Name="PanelUcet"       Grid.Row="1" Visibility="Collapsed"/>
            <local:Nastavenia      x:Name="PanelNastavenia" Grid.Row="1" Visibility="Collapsed"/>

        </Grid>
    </Grid>
</Window>
