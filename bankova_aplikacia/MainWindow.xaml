<Window x:Class="bankova_aplikacia.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:bankova_aplikacia"
        mc:Ignorable="d"
        Title="MainWindow" Height="900" Width="1600">

    <Grid>
        <Grid.Background>
            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                <GradientStop Color="Black"/>
                <GradientStop Color="#FF15A1E5" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>
        <Image
            Source="/Assets/investicna_banka_logo-1-removebg-preview.png"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Width="343"
            Height="132"
            RenderOptions.BitmapScalingMode="HighQuality" Margin="10,10,0,0"/>
        <TextBlock Margin="0,0,1144,472" TextWrapping="Wrap" Text="Mesačný príjem:" Padding="5" FontSize="20" Foreground="White" Height="143" Width="248" HorizontalAlignment="Right" VerticalAlignment="Bottom">
            <TextBlock.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="Black"/>
                    <GradientStop Color="#FF1093CD" Offset="1"/>
                </LinearGradientBrush>
            </TextBlock.Background>
        </TextBlock>
        <Border BorderThickness="8" Margin="0,0,1138,465" CornerRadius="10" Padding="10" Height="157" VerticalAlignment="Bottom" HorizontalAlignment="Right" Width="260">
            <Border.BorderBrush>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="Black"/>
                    <GradientStop Color="#FF278585" Offset="1"/>
                </LinearGradientBrush>
            </Border.BorderBrush>
        </Border>
        <TextBox Margin="0,0,1161,493" TextWrapping="Wrap" Padding="5" Text="0" FontSize="30" Background="#FF3C65B0" BorderThickness="0" HorizontalAlignment="Right" Width="214" Height="50" VerticalAlignment="Bottom"/>

    </Grid>
</Window>
