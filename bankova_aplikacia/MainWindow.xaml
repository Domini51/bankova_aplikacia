<Window x:Class="bankova_aplikacia.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:bankova_aplikacia"
        mc:Ignorable="d"
        WindowState="Maximized"
        Title="Investičná Banka" Height="900" Width="800"
        Background="#F5F5F5">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,0,0,-6">
        <StackPanel Margin="30,20" Height="1385">

            <!-- MESACNY PRIJEM -->
            <Border Background="White" CornerRadius="10" Padding="20" Margin="0,0,0,20"
                    BorderBrush="#D0D0D0" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Mesačný príjem" FontSize="22" FontWeight="SemiBold" Foreground="#1A1A1A" Margin="0,0,0,10"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Name="MPrijem" KeyDown="MPrijem_KeyDown" Text="0" FontSize="28" LostFocus="SumaBox_LostFocus" GotFocus="SumaBox_GotFocus"
                                 BorderBrush="#D0D0D0" BorderThickness="1" Padding="10,8" Height="50" TextChanged="MPrijem_TextChanged" Foreground="Gray"/>
                        <Label Grid.Column="1" Content="€" FontSize="28" Padding="10,8"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- NUTNE VYDAVKY -->
            <Border Background="White" CornerRadius="10" Padding="20" Margin="0,0,0,20"
                    BorderBrush="#D0D0D0" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Nutné výdavky" FontSize="22" FontWeight="SemiBold" Foreground="#1A1A1A" Margin="0,0,0,10"/>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" x:Name="NazovV1" KeyDown="NazovVydavok_KeyDown" Text="Názov výdavku" FontSize="18"
                                 BorderBrush="#D0D0D0" BorderThickness="1" Padding="10,8" Height="45"
                                 Foreground="Gray" GotFocus="NazovBox_GotFocus" LostFocus="NazovBox_LostFocus"/>
                        <TextBox Grid.Column="1" x:Name="Suma1" KeyDown="SumaVydavok_KeyDown" Text="0" FontSize="18" Margin="10,0,0,0"
                                 BorderBrush="#D0D0D0" BorderThickness="1" Padding="10,8" Height="45"
                                 Foreground="Gray" GotFocus="SumaBox_GotFocus" LostFocus="SumaBox_LostFocus"/>
                        <Label Grid.Column="2" Content="€" FontSize="22" Padding="6,8"/>
                        <Button Grid.Column="3" Content="+" FontSize="24" Height="45" Width="45"
                                Background="#1A1A1A" Foreground="White" BorderThickness="0"
                                Click="Button_Click"/>
                    </Grid>
                    <ListBox x:Name="ZoznamVydavkov" FontSize="18" MinHeight="60"
                             BorderBrush="#D0D0D0" BorderThickness="1" Padding="5"/>
                </StackPanel>
            </Border>

            <!-- HLAVNE VYDAVKY -->
            <Border Background="White" CornerRadius="10" Padding="20" Margin="0,0,0,20"
                    BorderBrush="#D0D0D0" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Hlavné výdavky" FontSize="22" FontWeight="SemiBold" Foreground="#1A1A1A" Margin="0,0,0,10"/>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" x:Name="NazovV1_Copy" KeyDown="NazovVydavok_KeyDown" Text="Názov výdavku" FontSize="18"
                                 BorderBrush="#D0D0D0" BorderThickness="1" Padding="10,8" Height="45"
                                 Foreground="Gray" GotFocus="NazovBox_GotFocus" LostFocus="NazovBox_LostFocus"/>
                        <TextBox Grid.Column="1" x:Name="Suma1_Copy" KeyDown="SumaVydavok_KeyDown" Text="0" FontSize="18" Margin="10,0,0,0"
                                 BorderBrush="#D0D0D0" BorderThickness="1" Padding="10,8" Height="45"
                                 Foreground="Gray" GotFocus="SumaBox_GotFocus" LostFocus="SumaBox_LostFocus"/>
                        <Label Grid.Column="2" Content="€" FontSize="22" Padding="6,8"/>
                        <Button Grid.Column="3" Content="+" FontSize="24" Height="45" Width="45"
                                Background="#1A1A1A" Foreground="White" BorderThickness="0"
                                Click="Button_Click"/>
                    </Grid>
                    <ListBox x:Name="ZoznamVydavkov_Copy" FontSize="18" MinHeight="60"
                             BorderBrush="#D0D0D0" BorderThickness="1" Padding="5"/>
                </StackPanel>
            </Border>

            <!-- OSOBNE VYDAVKY -->
            <Border Background="White" CornerRadius="10" Padding="20" Margin="0,0,0,20"
                    BorderBrush="#D0D0D0" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Osobné výdavky" FontSize="22" FontWeight="SemiBold" Foreground="#1A1A1A" Margin="0,0,0,10"/>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" x:Name="NazovV1_Copy1" KeyDown="NazovVydavok_KeyDown" Text="Názov výdavku" FontSize="18"
                                 BorderBrush="#D0D0D0" BorderThickness="1" Padding="10,8" Height="45"
                                 Foreground="Gray" GotFocus="NazovBox_GotFocus" LostFocus="NazovBox_LostFocus"/>
                        <TextBox Grid.Column="1" x:Name="Suma1_Copy1" KeyDown="SumaVydavok_KeyDown" Text="0" FontSize="18" Margin="10,0,0,0"
                                 BorderBrush="#D0D0D0" BorderThickness="1" Padding="10,8" Height="45"
                                 Foreground="Gray" GotFocus="SumaBox_GotFocus" LostFocus="SumaBox_LostFocus"/>
                        <Label Grid.Column="2" Content="€" FontSize="22" Padding="6,8"/>
                        <Button Grid.Column="3" Content="+" FontSize="24" Height="45" Width="45"
                                Background="#1A1A1A" Foreground="White" BorderThickness="0"
                                Click="Button_Click"/>
                    </Grid>
                    <ListBox x:Name="ZoznamVydavkov_Copy1" FontSize="18" MinHeight="60"
                             BorderBrush="#D0D0D0" BorderThickness="1" Padding="5"/>
                </StackPanel>
            </Border>

            <!-- VOLNE VYDAVKY -->
            <Border Background="White" CornerRadius="10" Padding="20" Margin="0,0,0,20"
                    BorderBrush="#D0D0D0" BorderThickness="1" RenderTransformOrigin="0.5,0.392">
                <StackPanel>
                    <TextBlock Text="Voľné výdavky" FontSize="22" FontWeight="SemiBold" Foreground="#1A1A1A" Margin="0,0,0,10"/>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" x:Name="NazovV1_Copy2" KeyDown="NazovVydavok_KeyDown" Text="Názov výdavku" FontSize="18"
                                 BorderBrush="#D0D0D0" BorderThickness="1" Padding="10,8" Height="45"
                                 Foreground="Gray" GotFocus="NazovBox_GotFocus" LostFocus="NazovBox_LostFocus"/>
                        <TextBox Grid.Column="1" x:Name="Suma1_Copy2" KeyDown="SumaVydavok_KeyDown" Text="0" FontSize="18" Margin="10,0,0,0"
                                 BorderBrush="#D0D0D0" BorderThickness="1" Padding="10,8" Height="45"
                                 Foreground="Gray" GotFocus="SumaBox_GotFocus" LostFocus="SumaBox_LostFocus"/>
                        <Label Grid.Column="2" Content="€" FontSize="22" Padding="6,8"/>
                        <Button Grid.Column="3" Content="+" FontSize="24" Height="45" Width="45"
                                Background="#1A1A1A" Foreground="White" BorderThickness="0"
                                Click="Button_Click"/>
                    </Grid>
                    <ListBox x:Name="ZoznamVydavkov_Copy2" FontSize="18" MinHeight="60"
                             BorderBrush="#D0D0D0" BorderThickness="1" Padding="5"/>
                </StackPanel>
            </Border>

            <!-- SUHRN -->
            <Border Background="White" CornerRadius="10" Padding="20" Margin="0,0,0,20"
                    BorderBrush="#D0D0D0" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Súhrn" FontSize="22" FontWeight="SemiBold" Foreground="#1A1A1A" Margin="0,0,0,15"/>
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="#F5F5F5" CornerRadius="8" Padding="15">
                            <StackPanel>
                                <TextBlock Text="Celkom minuté" FontSize="14" Foreground="#888888" Margin="0,0,0,5"/>
                                <TextBlock x:Name="TxtMinute" Text="0 €" FontSize="28" FontWeight="SemiBold" Foreground="#1A1A1A"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2" Background="#F5F5F5" CornerRadius="8" Padding="15">
                            <StackPanel>
                                <TextBlock Text="Zostatok" FontSize="14" Foreground="#888888" Margin="0,0,0,5"/>
                                <TextBlock x:Name="TxtZostatok" Text="0 €" FontSize="28" FontWeight="SemiBold" Foreground="#1A1A1A"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                    <TextBlock Text="Miera výdavkov" FontSize="14" Foreground="#888888" Margin="0,0,0,5"/>
                    <ProgressBar x:Name="ProgressBar" Height="20" Minimum="0" Maximum="100" Value="0"
                                 Background="#E0E0E0" BorderThickness="0"/>
                    <Button Content="Vypočítať"
                            Height="46" Margin="0,15,0,10"
                            Background="#1A1A1A" Foreground="White"
                            FontSize="16" FontWeight="SemiBold" BorderThickness="0"
                            Click="BtnVypocitat_Click"/>
                    <Button Content="Ako investovať zostatok"
                            Height="46"
                            Background="#555555" Foreground="White"
                            FontSize="16" FontWeight="SemiBold" BorderThickness="0"
                            Click="BtnInvestovat_Click"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>

</Window>