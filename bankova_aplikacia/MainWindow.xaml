<Window x:Class="bankova_aplikacia.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:bankova_aplikacia"
        mc:Ignorable="d"
        Title="MainWindow" Height="900" Width="1600"
        ResizeMode="NoResize">

    <Grid Height="884" VerticalAlignment="Center" HorizontalAlignment="Left" Width="1600" Background="White">
        <Image
            Source="/Assets/investicna_banka_logo-1-removebg-preview.png"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Width="343"
            Height="132"
            RenderOptions.BitmapScalingMode="HighQuality" Margin="10,10,0,0"/>
        <TextBlock Margin="0,0,494,616" TextWrapping="Wrap" Text="Mesačný príjem:" Padding="10" FontSize="35" Foreground="White" Height="190" Width="587" HorizontalAlignment="Right" VerticalAlignment="Bottom" Background="Silver"/>
        <Border BorderThickness="8" Margin="0,0,490,611" CornerRadius="10" Padding="10" Height="200" VerticalAlignment="Bottom" HorizontalAlignment="Right" Width="595" BorderBrush="#FF686868"/>
        <TextBox Margin="0,0,535,648" TextWrapping="Wrap" Padding="7" Name="MPrijem" Text="0" FontSize="35" Background="White" BorderThickness="0" HorizontalAlignment="Right" Width="505" Height="67" VerticalAlignment="Bottom"/>
        <Label Content="€" HorizontalAlignment="Right" Margin="0,0,535,648" VerticalAlignment="Bottom" FontSize="40" Height="67" Width="40"/>
        <TextBlock
        Width="547" VerticalAlignment="Bottom" Text="Nutné výdavky:" TextWrapping="Wrap" Padding="15" Margin="0,0,785,318" Height="276" HorizontalAlignment="Right" FontSize="40" Foreground="White" Background="#FFB4B4B4"/>
        <Border
        Width="549" VerticalAlignment="Top" Padding="10" Margin="263,281,0,0" Height="292" HorizontalAlignment="Left" CornerRadius="10" BorderThickness="8" BorderBrush="#FF646464" RenderTransformOrigin="0.5,0.5">
            <Border.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform/>
                    <RotateTransform Angle="0.348"/>
                    <TranslateTransform/>
                </TransformGroup>
            </Border.RenderTransform>
        </Border>
        <TextBox    Name="Suma1"
        Width="365" VerticalAlignment="Bottom" Text="0" TextWrapping="Wrap" Padding="5" Margin="0,0,928,328" Height="55" Foreground="Gray" HorizontalAlignment="Right" FontSize="35" Background="White" BorderThickness="0" GotFocus="SumaBox_GotFocus" LostFocus="SumaBox_LostFocus"/>
        <Label
        Width="67" VerticalAlignment="Bottom" Padding="10" Margin="0,0,928,328" Height="71" HorizontalAlignment="Right" FontSize="45" Content="€"/>
        <TextBox Name="NazovV1"
        Width="471" VerticalAlignment="Top" Text="Názov výdavku" TextWrapping="Wrap" Padding="7" Margin="306,428,0,0" Height="58" HorizontalAlignment="Left" FontSize="30" BorderThickness="0" GotFocus="NazovBox_GotFocus"
         LostFocus="NazovBox_LostFocus" Foreground="Gray"/>
        <Button Content="+" HorizontalAlignment="Left" Margin="682,501,0,0" VerticalAlignment="Top" Height="55" Width="95" FontSize="35" Padding="0" Click="Button_Click"/>
        <ListBox d:ItemsSource="{d:SampleData ItemCount=5}" Padding="7" FontSize="30" Margin="307,364,823,467" Name="ZoznamVydavkov"/>
        
    </Grid>
</Window>
