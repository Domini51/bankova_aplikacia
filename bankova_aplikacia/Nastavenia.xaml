 <UserControl x:Class="bankova_aplikacia.Nastavenia"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel HorizontalAlignment="Left" MaxWidth="500" Margin="30,20">

            <Border Padding="20"
                    Margin="0,0,0,16"
                    Background="{DynamicResource PanelBg}"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource PanelBorder}"
                    CornerRadius="10">
                <StackPanel>

                    <TextBlock Text="Účet"
                               Margin="0,0,0,15"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource HlavnyText}"/>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Meno"
                                       Margin="0,0,0,4"
                                       FontSize="13"
                                       Foreground="{DynamicResource SekundarnyText}"/>
                            <TextBlock x:Name="TxtMeno"
                                       Text=""
                                       FontSize="15"
                                       Foreground="{DynamicResource HlavnyText}"/>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Click="BtnZmenitMeno_Click"
                                Content="Zmeniť"
                                Height="36" Width="90"
                                FontSize="13"
                                VerticalAlignment="Center"
                                Background="Transparent"
                                Foreground="{DynamicResource HlavnyText}"
                                BorderBrush="{DynamicResource PanelBorder}"
                                BorderThickness="1"/>
                    </Grid>

                    <Border Height="1" Background="{DynamicResource Oddelovac}" Margin="0,0,0,12"/>

                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="Email"
                                   Margin="0,0,0,4"
                                   FontSize="13"
                                   Foreground="{DynamicResource SekundarnyText}"/>
                        <TextBlock x:Name="TxtEmail"
                                   Text=""
                                   FontSize="15"
                                   Foreground="{DynamicResource HlavnyText}"/>
                    </StackPanel>

                    <Border Height="1" Background="{DynamicResource Oddelovac}" Margin="0,0,0,12"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Heslo"
                                       Margin="0,0,0,4"
                                       FontSize="13"
                                       Foreground="{DynamicResource SekundarnyText}"/>
                            <TextBlock Text="••••••••"
                                       FontSize="15"
                                       Foreground="{DynamicResource HlavnyText}"/>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Click="BtnZmenitHeslo_Click"
                                Content="Zmeniť"
                                Height="36" Width="90"
                                FontSize="13"
                                VerticalAlignment="Center"
                                Background="Transparent"
                                Foreground="{DynamicResource HlavnyText}"
                                BorderBrush="{DynamicResource PanelBorder}"
                                BorderThickness="1"/>
                    </Grid>

                </StackPanel>
            </Border>

            <!-- tema -->
            <Border Padding="20"
                    Margin="0,0,0,16"
                    Background="{DynamicResource PanelBg}"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource PanelBorder}"
                    CornerRadius="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Tmavý režim"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource HlavnyText}"/>
                        <TextBlock Text="Prepnúť medzi svetlým a tmavým vzhľadom"
                                   Margin="0,3,0,0"
                                   FontSize="13"
                                   Foreground="{DynamicResource SekundarnyText}"/>
                    </StackPanel>

                    <Button Grid.Column="1"
                            x:Name="BtnTema"
                            Click="BtnTema_Click"
                            Content="Prepnúť"
                            Height="36" Width="90"
                            FontSize="13"
                            VerticalAlignment="Center"
                            Background="#1A1A1A"
                            Foreground="White"
                            BorderThickness="0"/>
                </Grid>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
