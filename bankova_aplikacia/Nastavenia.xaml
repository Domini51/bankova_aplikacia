<UserControl x:Class="bankova_aplikacia.Nastavenia"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="520" Margin="30,20">

            <TextBlock Text="Nastavenia"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="{DynamicResource HlavnyText}"
                       Margin="0,0,0,24"/>

            <Border Padding="24"
                    Margin="0,0,0,16"
                    Background="{DynamicResource PanelBg}"
                    BorderBrush="{DynamicResource PanelBorder}"
                    BorderThickness="1"
                    CornerRadius="12">
                <StackPanel>

                    <TextBlock Text="PROFIL"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource SekundarnyText}"
                               Margin="0,0,0,16"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <Border Width="54" Height="54"
                                Background="{DynamicResource AkcentFarba}"
                                CornerRadius="27">
                            <TextBlock x:Name="TxtInitials"
                                       Text="?"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                            <TextBlock x:Name="TxtMeno"
                                       FontSize="17"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource HlavnyText}"/>
                            <TextBlock x:Name="TxtEmail"
                                       FontSize="13"
                                       Foreground="{DynamicResource SekundarnyText}"
                                       Margin="0,3,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <Border Height="1" Background="{DynamicResource Oddelovac}" Margin="0,0,0,16"/>

                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Meno"
                                       FontSize="13"
                                       Foreground="{DynamicResource HlavnyText}"/>
                            <TextBlock Text="Zmeniť zobrazované meno"
                                       FontSize="12"
                                       Foreground="{DynamicResource SekundarnyText}"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                        <Button Grid.Column="1"
                                Click="BtnZmenitMeno_Click"
                                Content="Zmeniť"
                                Height="36" Width="90"
                                FontSize="13"
                                VerticalAlignment="Center"
                                Background="Transparent"
                                Foreground="{DynamicResource HlavnyText}"
                                BorderBrush="{DynamicResource PanelBorder}"
                                BorderThickness="1"/>
                    </Grid>

                    <Border Height="1" Background="{DynamicResource Oddelovac}" Margin="0,0,0,14"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Heslo"
                                       FontSize="13"
                                       Foreground="{DynamicResource HlavnyText}"/>
                            <TextBlock Text="Zmeniť prihlasovacie heslo"
                                       FontSize="12"
                                       Foreground="{DynamicResource SekundarnyText}"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                        <Button Grid.Column="1"
                                Click="BtnZmenitHeslo_Click"
                                Content="Zmeniť"
                                Height="36" Width="90"
                                FontSize="13"
                                VerticalAlignment="Center"
                                Background="Transparent"
                                Foreground="{DynamicResource HlavnyText}"
                                BorderBrush="{DynamicResource PanelBorder}"
                                BorderThickness="1"/>
                    </Grid>

                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>