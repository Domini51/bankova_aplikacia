 <UserControl x:Class="bankova_aplikacia.Nastavenia"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel HorizontalAlignment="Left" MaxWidth="500" Margin="30,20">

            <Border Padding="20"
                    Margin="0,0,0,16"
                    Background="White"
                    BorderThickness="1"
                    BorderBrush="#D0D0D0"
                    CornerRadius="10">
                <StackPanel>

                    <TextBlock Text="Účet"
                               Margin="0,0,0,15"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#1A1A1A"/>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Meno"
                                       Margin="0,0,0,4"
                                       FontSize="13"
                                       Foreground="#888888"/>
                            <TextBlock x:Name="TxtMeno"
                                       Text=""
                                       FontSize="15"
                                       Foreground="#1A1A1A"/>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Click="BtnZmenitMeno_Click"
                                Content="Zmeniť"
                                Height="36" Width="90"
                                FontSize="13"
                                VerticalAlignment="Center"
                                Background="Transparent"
                                Foreground="#1A1A1A"
                                BorderBrush="#D0D0D0"
                                BorderThickness="1"/>
                    </Grid>

                    <Border Height="1" Background="#E0E0E0" Margin="0,0,0,12"/>

                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="Email"
                                   Margin="0,0,0,4"
                                   FontSize="13"
                                   Foreground="#888888"/>
                        <TextBlock x:Name="TxtEmail"
                                   Text=""
                                   FontSize="15"
                                   Foreground="#1A1A1A"/>
                    </StackPanel>

                    <Border Height="1" Background="#E0E0E0" Margin="0,0,0,12"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Heslo"
                                       Margin="0,0,0,4"
                                       FontSize="13"
                                       Foreground="#888888"/>
                            <TextBlock Text="••••••••"
                                       FontSize="15"
                                       Foreground="#1A1A1A"/>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Click="BtnZmenitHeslo_Click"
                                Content="Zmeniť"
                                Height="36" Width="90"
                                FontSize="13"
                                VerticalAlignment="Center"
                                Background="Transparent"
                                Foreground="#1A1A1A"
                                BorderBrush="#D0D0D0"
                                BorderThickness="1"/>
                    </Grid>

                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>