<UserControl x:Class="bankova_aplikacia.Nastavenia"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#F5F5F7">
        <StackPanel Margin="32,28" MaxWidth="480" HorizontalAlignment="Left">

            <StackPanel Orientation="Horizontal" Margin="0,0,0,18"/>

            <Border Background="White" CornerRadius="12"
                    BorderBrush="#EBEBEB" BorderThickness="1">
                <StackPanel>
                    <Border CornerRadius="12,12,0,0" Padding="20,16" Background="#F5F5F5">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="38" Height="38" CornerRadius="19"
                                    Background="#F0F0F0" Margin="0,0,12,0">
                                <TextBlock Text="U" FontSize="16" FontWeight="SemiBold"
                                           Foreground="#1A1A1A"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Účet" FontSize="16" FontWeight="SemiBold"
                                           Foreground="#1A1A1A"/>
                                <TextBlock Text="Správa profilu a bezpečnosti"
                                           FontSize="11" Foreground="#888888" Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Height="1" Background="#EBEBEB"/>

                    <Border Padding="20,16">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Meno" FontSize="10" Foreground="#888888"
                                               FontWeight="SemiBold" Margin="0,0,0,3"/>
                                    <TextBlock x:Name="TxtMeno" Text="" FontSize="14" Foreground="#1A1A1A"/>
                                </StackPanel>
                                <Border Grid.Column="1" CornerRadius="8" Background="#F0F0F0"
                                        Padding="12,7" VerticalAlignment="Center">
                                    <Button Content="Zmeniť" Height="Auto"
                                            Background="Transparent" Foreground="#1A1A1A"
                                            BorderThickness="0" FontSize="12" FontWeight="Medium"
                                            Click="BtnZmenitMeno_Click"/>
                                </Border>
                            </Grid>

                            <Border Height="1" Background="#EBEBEB" Margin="0,14,0,14"/>

                            <StackPanel>
                                <TextBlock Text="Email" FontSize="10" Foreground="#888888"
                                           FontWeight="SemiBold" Margin="0,0,0,3"/>
                                <TextBlock x:Name="TxtEmail" Text="" FontSize="14" Foreground="#1A1A1A"/>
                            </StackPanel>

                            <Border Height="1" Background="#EBEBEB" Margin="0,14,0,14"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Heslo" FontSize="10" Foreground="#888888"
                                               FontWeight="SemiBold" Margin="0,0,0,3"/>
                                    <TextBlock Text="••••••••" FontSize="14" Foreground="#1A1A1A"/>
                                </StackPanel>
                                <Border Grid.Column="1" CornerRadius="8" Background="#F0F0F0"
                                        Padding="12,7" VerticalAlignment="Center">
                                    <Button Content="Zmeniť" Height="Auto"
                                            Background="Transparent" Foreground="#1A1A1A"
                                            BorderThickness="0" FontSize="12" FontWeight="Medium"
                                            Click="BtnZmenitHeslo_Click"/>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>