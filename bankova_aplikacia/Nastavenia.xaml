<UserControl x:Class="bankova_aplikacia.Nastavenia"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="30,20" MaxWidth="500" HorizontalAlignment="Left">
            <Border Background="White" CornerRadius="10" Padding="20" Margin="0,0,0,16"
                    BorderBrush="#D0D0D0" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Účet" FontSize="18" FontWeight="SemiBold" Foreground="#1A1A1A" Margin="0,0,0,15"/>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Meno" FontSize="13" Foreground="#888888" Margin="0,0,0,4"/>
                            <TextBlock x:Name="TxtMeno" Text="" FontSize="15" Foreground="#1A1A1A"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="Zmeniť" Height="36" Width="90"
                                Background="Transparent" Foreground="#1A1A1A"
                                BorderBrush="#D0D0D0" BorderThickness="1" FontSize="13"
                                VerticalAlignment="Center" Click="BtnZmenitMeno_Click"/>
                    </Grid>
                    <Border Height="1" Background="#E0E0E0" Margin="0,0,0,12"/>
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="Email" FontSize="13" Foreground="#888888" Margin="0,0,0,4"/>
                        <TextBlock x:Name="TxtEmail" Text="" FontSize="15" Foreground="#1A1A1A"/>
                    </StackPanel>
                    <Border Height="1" Background="#E0E0E0" Margin="0,0,0,12"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Heslo" FontSize="13" Foreground="#888888" Margin="0,0,0,4"/>
                            <TextBlock Text="••••••••" FontSize="15" Foreground="#1A1A1A"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="Zmeniť" Height="36" Width="90"
                                Background="Transparent" Foreground="#1A1A1A"
                                BorderBrush="#D0D0D0" BorderThickness="1" FontSize="13"
                                VerticalAlignment="Center" Click="BtnZmenitHeslo_Click"/>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>