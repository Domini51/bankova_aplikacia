<Window x:Class="bankova_aplikacia.SplashScreen"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Width="500" Height="300"
        Background="#1A1A1A">
    <Grid>

        <!-- logo a nazov -->
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <Image Source="/Assets/investicna_banka_logo-1-removebg-preview.png.png"
                   Height="100" HorizontalAlignment="Center"
                   RenderOptions.BitmapScalingMode="HighQuality"/>
            <TextBlock Text="Investičná Banka"
                       FontSize="28" FontWeight="SemiBold"
                       Foreground="White" HorizontalAlignment="Center"
                       Margin="0,16,0,0"/>
            <TextBlock Text="Načítavam..."
                       FontSize="14" Foreground="#888888"
                       HorizontalAlignment="Center" Margin="0,8,0,0"/>
        </StackPanel>

        <!-- loading bar na spodku -->
        <ProgressBar x:Name="LoadingBar"
                     Height="3" VerticalAlignment="Bottom"
                     Background="#333333" Foreground="#2E6DA4"
                     BorderThickness="0" Minimum="0" Maximum="100" Value="0"/>

    </Grid>
</Window>