<Window x:Class="bankova_aplikacia.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Splash"
        Width="480" Height="280"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Border Background="#111111" CornerRadius="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Image Source="/Assets/investicna_banka_logo-1-removebg-preview.png.png"
                       Height="75"
                       HorizontalAlignment="Center"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Margin="40,0,40,28">
                <TextBlock x:Name="TxtStatus"
                           Text="Načítavam..."
                           Margin="0,0,0,6"
                           FontSize="11"
                           Foreground="#444444"
                           HorizontalAlignment="Left"/>
                <Border Height="3" Background="#1E1E1E" CornerRadius="2">
                    <Border x:Name="LoadingBar"
                            Height="3"
                            Width="0"
                            Background="HotPink"
                            CornerRadius="2"
                            HorizontalAlignment="Left">
                        <Border.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="LoadingBar"
                                                         Storyboard.TargetProperty="Width"
                                                         From="0" To="400"
                                                         Duration="0:0:2.5"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Border.Triggers>
                    </Border>
                </Border>
            </StackPanel>
        </Grid>
    </Border>
</Window>