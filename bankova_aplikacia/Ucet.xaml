<UserControl x:Class="bankova_aplikacia.Ucet"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF">
    <Grid>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="30,20">

                <!-- zostatok -->
                <Border Padding="20"
                        Margin="0,0,0,16"
                        Background="{DynamicResource PanelBg}"
                        BorderBrush="{DynamicResource PanelBorder}"
                        BorderThickness="1"
                        CornerRadius="10">
                    <StackPanel>
                        <TextBlock Text="Stav účtu"
                                   Margin="0,0,0,6"
                                   FontSize="13"
                                   Foreground="{DynamicResource SekundarnyText}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="TxtUcetZostatok"
                                       Text="0 €"
                                       FontSize="32"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource HlavnyText}"
                                       VerticalAlignment="Center"/>
                            <Button Grid.Column="1"
                                    Click="BtnVybrat_Click"
                                    Content="Výber"
                                    Height="43" Width="100"
                                    FontSize="14"
                                    VerticalAlignment="Center"
                                    Background="Black"
                                    Foreground="White"
                                    BorderThickness="0"/>
                        </Grid>
                        <Border Height="1" Background="{DynamicResource Oddelovac}" Margin="0,14,0,14"/>
                        <TextBlock Text="Hodnota portfólia"
                                   Margin="0,0,0,4"
                                   FontSize="13"
                                   Foreground="{DynamicResource SekundarnyText}"/>
                        <TextBlock x:Name="TxtCelkovePortfolio"
                                   Text="0 €"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource HlavnyText}"/>
                    </StackPanel>
                </Border>

                <!-- graf portfolia -->
                <Border Padding="20"
                        Margin="0,0,0,16"
                        Background="{DynamicResource PanelBg}"
                        BorderBrush="{DynamicResource PanelBorder}"
                        BorderThickness="1"
                        CornerRadius="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="380"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0"
                                   Text="Kde mám peniaze"
                                   Margin="0,0,0,10"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource HlavnyText}"/>
                        <lvc:PieChart Grid.Row="1"
                                      x:Name="GrafPortfolia"
                                      LegendPosition="Bottom"/>
                    </Grid>
                </Border>

                <!-- zoznam pozicii -->
                <Border Padding="20"
                        Margin="0,0,0,16"
                        Background="{DynamicResource PanelBg}"
                        BorderBrush="{DynamicResource PanelBorder}"
                        BorderThickness="1"
                        CornerRadius="10">
                    <StackPanel>
                        <TextBlock Text="Moje pozície"
                                   Margin="0,0,0,15"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource HlavnyText}"/>
                        <ItemsControl x:Name="ZoznamPortfolia">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="16"
                                            Margin="0,0,0,10"
                                            Background="{DynamicResource PolozkaBg}"
                                            CornerRadius="8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding Symbol}"
                                                           FontSize="16"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource HlavnyText}"/>
                                                <TextBlock Text="{Binding Info}"
                                                           Margin="0,4,0,0"
                                                           FontSize="13"
                                                           Foreground="{DynamicResource SekundarnyText}"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1"
                                                        Margin="0,0,16,0"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="{Binding AktualnaHodnota}"
                                                           FontSize="15"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource HlavnyText}"
                                                           HorizontalAlignment="Right"/>
                                                <TextBlock Text="{Binding ZiskStrata}"
                                                           Margin="0,4,0,0"
                                                           FontSize="13"
                                                           Foreground="{Binding ZiskStrataFarba}"
                                                           HorizontalAlignment="Right"/>
                                            </StackPanel>

                                            <Button Grid.Column="2"
                                                    Click="BtnPredat_Click"
                                                    Content="Predať"
                                                    Height="36" Width="80"
                                                    FontSize="13"
                                                    Background="#E24B4A"
                                                    Foreground="White"
                                                    BorderThickness="0"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock x:Name="TxtPrazdnePortfolio"
                                   Text="Žiadne pozície."
                                   Margin="0,10,0,0"
                                   FontSize="14"
                                   Foreground="{DynamicResource SekundarnyText}"
                                   Visibility="Collapsed"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- spinner -->
        <Grid x:Name="SpinnerOverlay"
              Background="{DynamicResource SpinnerBg}"
              Visibility="Collapsed">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border Width="60" Height="60">
                    <Border.RenderTransform>
                        <RotateTransform x:Name="SpinnerRotate" CenterX="30" CenterY="30"/>
                    </Border.RenderTransform>
                    <Border.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetName="SpinnerRotate"
                                                     Storyboard.TargetProperty="Angle"
                                                     From="0" To="360"
                                                     Duration="0:0:0.8"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Border.Triggers>
                    <Ellipse Width="60" Height="60"
                             Stroke="#1A1A1A"
                             StrokeThickness="5"
                             StrokeDashArray="10 5"/>
                </Border>
                <TextBlock Text="Chvíľku..."
                           Margin="0,12,0,0"
                           FontSize="14"
                           Foreground="{DynamicResource StrednyText}"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>

    </Grid>
</UserControl>