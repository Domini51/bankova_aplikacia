<UserControl x:Class="bankova_aplikacia.VypocetVydavkou"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF">
    <UserControl.Resources>
        <DataTemplate x:Key="VydavokTemplate">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding}" FontSize="15"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource HlavnyText}"/>
                <Button Grid.Column="1" Click="BtnOdstranVydavok_Click"
                        Content="✕" Width="26" Height="26" FontSize="11"
                        Background="Transparent" Foreground="#E24B4A"
                        BorderThickness="0" Margin="10,0,0,0"
                        VerticalAlignment="Center"/>
            </Grid>
        </DataTemplate>
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="30,20">

            <!-- prijem -->
            <Border Padding="20"
                    Background="{DynamicResource PanelBg}"
                    BorderBrush="{DynamicResource PanelBorder}"
                    BorderThickness="1"
                    CornerRadius="10">
                <StackPanel>
                    <TextBlock Text="Mesačný príjem"
                               Margin="0,0,0,10"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource HlavnyText}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="MPrijem"
                                 Grid.Column="0"
                                 Text="0"
                                 Height="46"
                                 FontSize="24"
                                 Padding="10,8"
                                 Foreground="{DynamicResource SekundarnyText}"
                                 Background="{DynamicResource VstupBg}"
                                 BorderBrush="{DynamicResource VstupBorder}"
                                 BorderThickness="1"
                                 GotFocus="SumaBox_GotFocus"
                                 LostFocus="SumaBox_LostFocus"
                                 TextChanged="MPrijem_TextChanged"
                                 KeyDown="MPrijem_KeyDown"/>
                        <Label Grid.Column="1" Content="€" FontSize="24" Padding="10,8" Foreground="{DynamicResource HlavnyText}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- nutne vydavky -->
            <Border Padding="20"
                    Margin="0,14,0,7"
                    Background="{DynamicResource PanelBg}"
                    BorderBrush="{DynamicResource PanelBorder}"
                    BorderThickness="1"
                    CornerRadius="10">
                <StackPanel>
                    <TextBlock Text="Nutné výdavky"
                               Margin="0,0,0,10"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource HlavnyText}"/>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="NazovV1"
                                 Grid.Column="0"
                                 Text="Názov výdavku"
                                 Height="42"
                                 FontSize="16"
                                 Padding="10,8"
                                 Foreground="{DynamicResource SekundarnyText}"
                                 Background="{DynamicResource VstupBg}"
                                 BorderBrush="{DynamicResource VstupBorder}"
                                 BorderThickness="1"
                                 GotFocus="NazovBox_GotFocus"
                                 LostFocus="NazovBox_LostFocus"
                                 KeyDown="NazovVydavok_KeyDown"/>
                        <TextBox x:Name="Suma1"
                                 Grid.Column="1"
                                 Text="0"
                                 Height="42"
                                 FontSize="16"
                                 Margin="10,0,0,0"
                                 Padding="10,8"
                                 Foreground="{DynamicResource SekundarnyText}"
                                 Background="{DynamicResource VstupBg}"
                                 BorderBrush="{DynamicResource VstupBorder}"
                                 BorderThickness="1"
                                 GotFocus="SumaBox_GotFocus"
                                 LostFocus="SumaBox_LostFocus"
                                 KeyDown="SumaVydavok_KeyDown"/>
                        <Label Grid.Column="2" Content="€" FontSize="20" Padding="6,8" Foreground="{DynamicResource HlavnyText}"/>
                        <Button Grid.Column="3"
                                Click="BtnPridajVydavok_Click"
                                Content="+"
                                Height="42" Width="42"
                                FontSize="22"
                                Background="#2E6DA4"
                                Foreground="White"
                                BorderThickness="0"/>
                    </Grid>
                    <ListBox x:Name="ZoznamVydavkov"
                             MinHeight="50"
                             FontSize="16"
                             Padding="5"
                             Background="{DynamicResource VstupBg}"
                             Foreground="{DynamicResource HlavnyText}"
                             BorderBrush="{DynamicResource VstupBorder}"
                             BorderThickness="1"
                             ItemTemplate="{StaticResource VydavokTemplate}"/>
                </StackPanel>
            </Border>

            <!-- hlavne vydavky -->
            <Border Padding="20"
                    Margin="0,7,0,7"
                    Background="{DynamicResource PanelBg}"
                    BorderBrush="{DynamicResource PanelBorder}"
                    BorderThickness="1"
                    CornerRadius="10">
                <StackPanel>
                    <TextBlock Text="Hlavné výdavky"
                               Margin="0,0,0,10"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource HlavnyText}"/>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="NazovV2"
                                 Grid.Column="0"
                                 Text="Názov výdavku"
                                 Height="42"
                                 FontSize="16"
                                 Padding="10,8"
                                 Foreground="{DynamicResource SekundarnyText}"
                                 Background="{DynamicResource VstupBg}"
                                 BorderBrush="{DynamicResource VstupBorder}"
                                 BorderThickness="1"
                                 GotFocus="NazovBox_GotFocus"
                                 LostFocus="NazovBox_LostFocus"
                                 KeyDown="NazovVydavok_KeyDown"/>
                        <TextBox x:Name="Suma2"
                                 Grid.Column="1"
                                 Text="0"
                                 Height="42"
                                 FontSize="16"
                                 Margin="10,0,0,0"
                                 Padding="10,8"
                                 Foreground="{DynamicResource SekundarnyText}"
                                 Background="{DynamicResource VstupBg}"
                                 BorderBrush="{DynamicResource VstupBorder}"
                                 BorderThickness="1"
                                 GotFocus="SumaBox_GotFocus"
                                 LostFocus="SumaBox_LostFocus"
                                 KeyDown="SumaVydavok_KeyDown"/>
                        <Label Grid.Column="2" Content="€" FontSize="20" Padding="6,8" Foreground="{DynamicResource HlavnyText}"/>
                        <Button Grid.Column="3"
                                Click="BtnPridajVydavok_Click"
                                Content="+"
                                Height="42" Width="42"
                                FontSize="22"
                                Background="#2E6DA4"
                                Foreground="White"
                                BorderThickness="0"/>
                    </Grid>
                    <ListBox x:Name="ZoznamVydavkov2"
                             MinHeight="50"
                             FontSize="16"
                             Padding="5"
                             Background="{DynamicResource VstupBg}"
                             Foreground="{DynamicResource HlavnyText}"
                             BorderBrush="{DynamicResource VstupBorder}"
                             BorderThickness="1"
                             ItemTemplate="{StaticResource VydavokTemplate}"/>
                </StackPanel>
            </Border>

            <!-- osobne vydavky -->
            <Border Padding="20"
                    Margin="0,7,0,7"
                    Background="{DynamicResource PanelBg}"
                    BorderBrush="{DynamicResource PanelBorder}"
                    BorderThickness="1"
                    CornerRadius="10">
                <StackPanel>
                    <TextBlock Text="Osobné výdavky"
                               Margin="0,0,0,10"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource HlavnyText}"/>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="NazovV3"
                                 Grid.Column="0"
                                 Text="Názov výdavku"
                                 Height="42"
                                 FontSize="16"
                                 Padding="10,8"
                                 Foreground="{DynamicResource SekundarnyText}"
                                 Background="{DynamicResource VstupBg}"
                                 BorderBrush="{DynamicResource VstupBorder}"
                                 BorderThickness="1"
                                 GotFocus="NazovBox_GotFocus"
                                 LostFocus="NazovBox_LostFocus"
                                 KeyDown="NazovVydavok_KeyDown"/>
                        <TextBox x:Name="Suma3"
                                 Grid.Column="1"
                                 Text="0"
                                 Height="42"
                                 FontSize="16"
                                 Margin="10,0,0,0"
                                 Padding="10,8"
                                 Foreground="{DynamicResource SekundarnyText}"
                                 Background="{DynamicResource VstupBg}"
                                 BorderBrush="{DynamicResource VstupBorder}"
                                 BorderThickness="1"
                                 GotFocus="SumaBox_GotFocus"
                                 LostFocus="SumaBox_LostFocus"
                                 KeyDown="SumaVydavok_KeyDown"/>
                        <Label Grid.Column="2" Content="€" FontSize="20" Padding="6,8" Foreground="{DynamicResource HlavnyText}"/>
                        <Button Grid.Column="3"
                                Click="BtnPridajVydavok_Click"
                                Content="+"
                                Height="42" Width="42"
                                FontSize="22"
                                Background="#2E6DA4"
                                Foreground="White"
                                BorderThickness="0"/>
                    </Grid>
                    <ListBox x:Name="ZoznamVydavkov3"
                             MinHeight="50"
                             FontSize="16"
                             Padding="5"
                             Background="{DynamicResource VstupBg}"
                             Foreground="{DynamicResource HlavnyText}"
                             BorderBrush="{DynamicResource VstupBorder}"
                             BorderThickness="1"
                             ItemTemplate="{StaticResource VydavokTemplate}"/>
                </StackPanel>
            </Border>

            <!-- volne vydavky -->
            <Border Padding="20"
                    Margin="0,7,0,15"
                    Background="{DynamicResource PanelBg}"
                    BorderBrush="{DynamicResource PanelBorder}"
                    BorderThickness="1"
                    CornerRadius="10">
                <StackPanel>
                    <TextBlock Text="Voľné výdavky"
                               Margin="0,0,0,10"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource HlavnyText}"/>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="NazovV4"
                                 Grid.Column="0"
                                 Text="Názov výdavku"
                                 Height="42"
                                 FontSize="16"
                                 Padding="10,8"
                                 Foreground="{DynamicResource SekundarnyText}"
                                 Background="{DynamicResource VstupBg}"
                                 BorderBrush="{DynamicResource VstupBorder}"
                                 BorderThickness="1"
                                 GotFocus="NazovBox_GotFocus"
                                 LostFocus="NazovBox_LostFocus"
                                 KeyDown="NazovVydavok_KeyDown"/>
                        <TextBox x:Name="Suma4"
                                 Grid.Column="1"
                                 Text="0"
                                 Height="42"
                                 FontSize="16"
                                 Margin="10,0,0,0"
                                 Padding="10,8"
                                 Foreground="{DynamicResource SekundarnyText}"
                                 Background="{DynamicResource VstupBg}"
                                 BorderBrush="{DynamicResource VstupBorder}"
                                 BorderThickness="1"
                                 GotFocus="SumaBox_GotFocus"
                                 LostFocus="SumaBox_LostFocus"
                                 KeyDown="SumaVydavok_KeyDown"/>
                        <Label Grid.Column="2" Content="€" FontSize="20" Padding="6,8" Foreground="{DynamicResource HlavnyText}"/>
                        <Button Grid.Column="3"
                                Click="BtnPridajVydavok_Click"
                                Content="+"
                                Height="42" Width="42"
                                FontSize="22"
                                Background="#2E6DA4"
                                Foreground="White"
                                BorderThickness="0"/>
                    </Grid>
                    <ListBox x:Name="ZoznamVydavkov4"
                             MinHeight="50"
                             FontSize="16"
                             Padding="5"
                             Background="{DynamicResource VstupBg}"
                             Foreground="{DynamicResource HlavnyText}"
                             BorderBrush="{DynamicResource VstupBorder}"
                             BorderThickness="1"
                             ItemTemplate="{StaticResource VydavokTemplate}"/>
                </StackPanel>
            </Border>

            <!-- suhrn -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0"
                        Padding="20,16"
                        Margin="0,0,8,0"
                        Background="{DynamicResource PanelBg}"
                        BorderBrush="{DynamicResource PanelBorder}"
                        BorderThickness="1"
                        CornerRadius="10">
                    <StackPanel>
                        <TextBlock Text="Mesačný príjem"
                                   Margin="0,0,0,6"
                                   FontSize="13"
                                   Foreground="{DynamicResource SekundarnyText}"/>
                        <TextBlock x:Name="MetPrijem"
                                   Text="0 €"
                                   FontSize="26"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource HlavnyText}"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="2"
                        Padding="20,16"
                        Margin="6,0,0,0"
                        Background="{DynamicResource PanelBg}"
                        BorderBrush="{DynamicResource PanelBorder}"
                        BorderThickness="1"
                        CornerRadius="10">
                    <StackPanel>
                        <TextBlock Text="Celkom minuté"
                                   Margin="0,0,0,6"
                                   FontSize="13"
                                   Foreground="{DynamicResource SekundarnyText}"/>
                        <TextBlock x:Name="MetMinute"
                                   Text="0 €"
                                   FontSize="26"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource HlavnyText}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- graf -->
            <Border Padding="20"
                    Background="{DynamicResource PanelBg}"
                    BorderBrush="{DynamicResource PanelBorder}"
                    BorderThickness="1"
                    CornerRadius="10">
                <StackPanel Height="351">
                    <TextBlock Text="Rozloženie výdavkov"
                               Margin="0,0,0,10"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource HlavnyText}"/>
                    <lvc:PieChart x:Name="GrafVydavkov"
                                  Height="318"
                                  LegendPosition="Right"
                                  Loaded="GrafVydavkov_Loaded"/>
                </StackPanel>
            </Border>

            <Button Click="BtnUlozZostatokNaUcet_Click"
                    Content="Uložiť zostatok na účet"
                    Height="46"
                    Margin="0,14,0,20"
                    FontSize="15"
                    FontWeight="SemiBold"
                    Background="#2E6DA4"
                    Foreground="White"
                    BorderThickness="0"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>