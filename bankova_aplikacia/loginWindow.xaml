<Window x:Class="bankova_aplikacia.loginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:bankova_aplikacia"
        mc:Ignorable="d"
        Title="Investičná Banka"
        Height="600" Width="1000"
        MinHeight="400" MinWidth="700"
        WindowState="Maximized">

    <Grid Background="Black">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="550"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- lava strana -->
        <Grid Grid.Column="0">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                    <GradientStop Color="Black"/>
                    <GradientStop Color="Black" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Image Source="/Assets/investicna_banka_logo-1-removebg-preview.png.png"
                       Width="325"
                       Margin="0,0,0,24"
                       HorizontalAlignment="Center"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
                <Border Height="2" Width="40" Background="White" Margin="0,0,0,24"/>
                <TextBlock Text="Spravujte svoje financie"
                           FontSize="25"
                           Foreground="#666666"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="a investície na jednom mieste."
                           Margin="0,4,0,0"
                           FontSize="25"
                           Foreground="#666666"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- prava strana -->
        <Grid Grid.Column="1" Background="{DynamicResource LoginPanelBg}">
            <Border Width="420"
                    Padding="48,44"
                    Background="{DynamicResource LoginKartaBg}"
                    BorderBrush="{DynamicResource LoginKartaBorder}"
                    BorderThickness="1"
                    CornerRadius="12"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">
                <StackPanel>

                    <!-- taby -->
                    <Grid Margin="0,0,0,28">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="Login"
                                Click="BtnLogin_Click"
                                Grid.Column="0"
                                Content="Prihlásenie"
                                Height="42"
                                FontSize="15"
                                FontWeight="SemiBold"
                                Background="Transparent"
                                Foreground="#1A1A1A"
                                BorderThickness="0,0,0,2"
                                BorderBrush="#1A1A1A"/>
                        <Button x:Name="Register"
                                Click="BtnRegister_Click"
                                Grid.Column="1"
                                Content="Registrácia"
                                Height="42"
                                FontSize="15"
                                FontWeight="Normal"
                                Background="Transparent"
                                Foreground="#AAAAAA"
                                BorderThickness="0,0,0,1"
                                BorderBrush="#E0E0E0"/>
                    </Grid>

                    <!-- login panel -->
                    <Border x:Name="PanelLoginBorder" Visibility="Visible">
                        <StackPanel>
                            <TextBlock Text="Email"
                                       Margin="0,0,0,6"
                                       FontSize="13"
                                       Foreground="#888888"/>
                            <TextBox x:Name="LoginMeno"
                                     Height="46"
                                     FontSize="15"
                                     Padding="14,10"
                                     Margin="0,0,0,16"
                                     BorderBrush="#E0E0E0"
                                     BorderThickness="1">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Style.Triggers>
                                            <Trigger Property="Text" Value="">
                                                <Setter Property="Background">
                                                    <Setter.Value>
                                                        <VisualBrush AlignmentX="Left" AlignmentY="Center" Stretch="None">
                                                            <VisualBrush.Visual>
                                                                <Label Content="vas@email.com" FontSize="14" Foreground="#BBBBBB"/>
                                                            </VisualBrush.Visual>
                                                        </VisualBrush>
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>

                            <TextBlock Text="Heslo"
                                       Margin="0,0,0,6"
                                       FontSize="13"
                                       Foreground="#888888"/>
                            <Grid Margin="0,0,0,20">
                                <PasswordBox x:Name="LoginHeslo"
                                             Height="46"
                                             FontSize="15"
                                             Padding="14,10"
                                             PasswordChanged="LoginHeslo_PasswordChanged">
                                    <PasswordBox.Style>
                                        <Style TargetType="PasswordBox">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="PasswordBox">
                                                        <Border Background="White"
                                                                BorderBrush="#E0E0E0"
                                                                BorderThickness="1"
                                                                CornerRadius="3">
                                                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </PasswordBox.Style>
                                </PasswordBox>
                                <TextBlock x:Name="LoginHesloHint"
                                           Text="••••••••"
                                           Padding="14,10,0,0"
                                           FontSize="15"
                                           Foreground="#BBBBBB"
                                           IsHitTestVisible="False"
                                           Visibility="Visible"/>
                            </Grid>

                            <Button x:Name="MainButton"
                                    Click="Button_Click"
                                    Content="Prihlásiť sa"
                                    Height="48"
                                    FontSize="16"
                                    FontWeight="SemiBold"
                                    Margin="0,0,0,14"
                                    Background="#1A1A1A"
                                    Foreground="White"
                                    BorderThickness="0"/>

                            <Button x:Name="ForgotPasswordButton"
                                    Click="Button_Click_1"
                                    Content="Zabudnuté heslo?"
                                    FontSize="13"
                                    Background="Transparent"
                                    Foreground="#888888"
                                    BorderThickness="0"
                                    HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- register panel -->
                    <Border x:Name="PanelRegisterBorder" Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="Meno"
                                       Margin="0,0,0,6"
                                       FontSize="13"
                                       Foreground="#888888"/>
                            <TextBox x:Name="RegisterMeno"
                                     Height="46"
                                     FontSize="15"
                                     Padding="14,10"
                                     Margin="0,0,0,16"
                                     BorderBrush="#E0E0E0"
                                     BorderThickness="1">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Style.Triggers>
                                            <Trigger Property="Text" Value="">
                                                <Setter Property="Background">
                                                    <Setter.Value>
                                                        <VisualBrush AlignmentX="Left" AlignmentY="Center" Stretch="None">
                                                            <VisualBrush.Visual>
                                                                <Label Content="Vaše meno" FontSize="14" Foreground="#BBBBBB"/>
                                                            </VisualBrush.Visual>
                                                        </VisualBrush>
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>

                            <TextBlock Text="Email"
                                       Margin="0,0,0,6"
                                       FontSize="13"
                                       Foreground="#888888"/>
                            <TextBox x:Name="RegisterGmail"
                                     Height="46"
                                     FontSize="15"
                                     Padding="14,10"
                                     Margin="0,0,0,16"
                                     BorderBrush="#E0E0E0"
                                     BorderThickness="1">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Style.Triggers>
                                            <Trigger Property="Text" Value="">
                                                <Setter Property="Background">
                                                    <Setter.Value>
                                                        <VisualBrush AlignmentX="Left" AlignmentY="Center" Stretch="None">
                                                            <VisualBrush.Visual>
                                                                <Label Content="vas@email.com" FontSize="14" Foreground="#BBBBBB"/>
                                                            </VisualBrush.Visual>
                                                        </VisualBrush>
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>

                            <TextBlock Text="Heslo"
                                       Margin="0,0,0,6"
                                       FontSize="13"
                                       Foreground="#888888"/>
                            <Grid Margin="0,0,0,20">
                                <PasswordBox x:Name="RegisterHeslo"
                                             Height="46"
                                             FontSize="15"
                                             Padding="14,10"
                                             PasswordChanged="RegisterHeslo_PasswordChanged">
                                    <PasswordBox.Style>
                                        <Style TargetType="PasswordBox">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="PasswordBox">
                                                        <Border Background="White"
                                                                BorderBrush="#E0E0E0"
                                                                BorderThickness="1"
                                                                CornerRadius="3">
                                                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </PasswordBox.Style>
                                </PasswordBox>
                                <TextBlock x:Name="RegisterHesloHint"
                                           Text="••••••••"
                                           Padding="14,10,0,0"
                                           FontSize="15"
                                           Foreground="#BBBBBB"
                                           IsHitTestVisible="False"
                                           Visibility="Visible"/>
                            </Grid>

                            <Button Click="Button_Click"
                                    Content="Registrovať sa"
                                    Height="48"
                                    FontSize="16"
                                    FontWeight="SemiBold"
                                    Background="#1A1A1A"
                                    Foreground="White"
                                    BorderThickness="0"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>