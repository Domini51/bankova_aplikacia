<Window x:Class="bankova_aplikacia.loginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Investičná Banka"
        Height="700" Width="1100"
        MinHeight="500" MinWidth="800"
        WindowState="Maximized"
        Background="#0D0D0D">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>

        <!-- ===== ĽAVÁ – branding ===== -->
        <Grid Grid.Column="0" ClipToBounds="True">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#161616" Offset="0"/>
                    <GradientStop Color="#0D0D0D" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>

            <!-- obrysové kruhy -->
            <Ellipse Width="450" Height="450"
                     HorizontalAlignment="Right" VerticalAlignment="Bottom"
                     Margin="0,0,-160,-160"
                     Stroke="#202020" StrokeThickness="1"
                     Fill="Transparent"/>

            <Ellipse Width="220" Height="220"
                     HorizontalAlignment="Left" VerticalAlignment="Top"
                     Margin="-60,-60,0,0"
                     Stroke="#1E1E1E" StrokeThickness="1"
                     Fill="Transparent"/>

            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Width="300">

                <Border Width="72" Height="72"
                        CornerRadius="18"
                        Background="White"
                        HorizontalAlignment="Left"
                        Margin="0,0,0,36">
                    <TextBlock Text="IB"
                               FontSize="28" FontWeight="Bold"
                               Foreground="#111111"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <TextBlock Text="Investičná Banka"
                           FontSize="34" FontWeight="Bold"
                           Foreground="White"
                           Margin="0,0,0,14"/>

                <TextBlock Text="Vaše investície na jednom mieste."
                           FontSize="15"
                           Foreground="#555555"
                           TextWrapping="Wrap"/>

            </StackPanel>
        </Grid>

        <!-- ===== PRAVÁ – formulár ===== -->
        <Grid Grid.Column="1" Background="#F5F5F7">

            <Border MaxWidth="580"
                    VerticalAlignment="Center"
                    Margin="60,0"
                    Background="White"
                    CornerRadius="20"
                    Padding="56,54">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="50" ShadowDepth="0"
                                      Opacity="0.1" Color="#000000"/>
                </Border.Effect>

                <StackPanel>

                    <TextBlock Text="Vitajte späť"
                               FontSize="30" FontWeight="Bold"
                               Foreground="#111111"
                               Margin="0,0,0,6"/>
                    <TextBlock Text="Prihláste sa do svojho účtu"
                               FontSize="16"
                               Foreground="#888888"
                               Margin="0,0,0,32"/>

                    <!-- taby -->
                    <Grid Margin="0,0,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="Login"
                                Click="BtnLogin_Click"
                                Grid.Column="0"
                                Content="Prihlásenie"
                                Height="38" FontSize="14" FontWeight="SemiBold"
                                Background="Transparent" Foreground="#111111"
                                BorderThickness="0,0,0,2" BorderBrush="#111111"/>
                        <Button x:Name="Register"
                                Click="BtnRegister_Click"
                                Grid.Column="1"
                                Content="Registrácia"
                                Height="38" FontSize="14"
                                Background="Transparent" Foreground="#AAAAAA"
                                BorderThickness="0,0,0,1" BorderBrush="#E0E0E0"/>
                    </Grid>

                    <!-- LOGIN -->
                    <Border x:Name="PanelLoginBorder" Visibility="Visible">
                        <StackPanel>
                            <TextBlock Text="Email" FontSize="12" FontWeight="SemiBold"
                                       Foreground="#555555" Margin="0,0,0,6"/>
                            <TextBox x:Name="LoginMeno"
                                     Height="52" FontSize="15" Padding="16,0"
                                     Margin="0,0,0,16" VerticalContentAlignment="Center"
                                     Background="#F8F8F8" BorderBrush="#E8E8E8" BorderThickness="1"
                                     KeyDown="Input_KeyDown">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Style.Triggers>
                                            <Trigger Property="Text" Value="">
                                                <Setter Property="Background">
                                                    <Setter.Value>
                                                        <VisualBrush AlignmentX="Left" AlignmentY="Center" Stretch="None">
                                                            <VisualBrush.Visual>
                                                                <Label Content="vas@email.com" FontSize="14" Foreground="#CCCCCC" Padding="14,0,0,0"/>
                                                            </VisualBrush.Visual>
                                                        </VisualBrush>
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>

                            <TextBlock Text="Heslo" FontSize="12" FontWeight="SemiBold"
                                       Foreground="#555555" Margin="0,0,0,6"/>
                            <Grid Margin="0,0,0,26">
                                <PasswordBox x:Name="LoginHeslo"
                                             Height="52" FontSize="15" Padding="16,0"
                                             VerticalContentAlignment="Center"
                                             PasswordChanged="LoginHeslo_PasswordChanged"
                                             KeyDown="Input_KeyDown">
                                    <PasswordBox.Style>
                                        <Style TargetType="PasswordBox">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="PasswordBox">
                                                        <Border Background="#F8F8F8" BorderBrush="#E8E8E8"
                                                                BorderThickness="1" CornerRadius="4">
                                                            <ScrollViewer x:Name="PART_ContentHost" Margin="14,0"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </PasswordBox.Style>
                                </PasswordBox>
                                <TextBlock x:Name="LoginHesloHint" Text="••••••••"
                                           Padding="14,0,0,0" FontSize="15" Foreground="#CCCCCC"
                                           VerticalAlignment="Center" IsHitTestVisible="False"/>
                            </Grid>

                            <Button x:Name="MainButton"
                                    Click="Button_Click"
                                    Content="Prihlásiť sa"
                                    Height="54" FontSize="16" FontWeight="SemiBold"
                                    Margin="0,0,0,12"
                                    Background="#111111" Foreground="White" BorderThickness="0">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <Button x:Name="ForgotPasswordButton"
                                    Click="Button_Click_1"
                                    Content="Zabudnuté heslo?"
                                    FontSize="13" Background="Transparent"
                                    Foreground="#AAAAAA" BorderThickness="0"
                                    HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- REGISTER -->
                    <Border x:Name="PanelRegisterBorder" Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="Meno" FontSize="12" FontWeight="SemiBold"
                                       Foreground="#555555" Margin="0,0,0,6"/>
                            <TextBox x:Name="RegisterMeno"
                                     Height="52" FontSize="15" Padding="16,0"
                                     Margin="0,0,0,14" VerticalContentAlignment="Center"
                                     Background="#F8F8F8" BorderBrush="#E8E8E8" BorderThickness="1"
                                     KeyDown="Input_KeyDown">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Style.Triggers>
                                            <Trigger Property="Text" Value="">
                                                <Setter Property="Background">
                                                    <Setter.Value>
                                                        <VisualBrush AlignmentX="Left" AlignmentY="Center" Stretch="None">
                                                            <VisualBrush.Visual>
                                                                <Label Content="Vaše meno" FontSize="14" Foreground="#CCCCCC" Padding="14,0,0,0"/>
                                                            </VisualBrush.Visual>
                                                        </VisualBrush>
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>

                            <TextBlock Text="Email" FontSize="12" FontWeight="SemiBold"
                                       Foreground="#555555" Margin="0,0,0,6"/>
                            <TextBox x:Name="RegisterGmail"
                                     Height="52" FontSize="15" Padding="16,0"
                                     Margin="0,0,0,14" VerticalContentAlignment="Center"
                                     Background="#F8F8F8" BorderBrush="#E8E8E8" BorderThickness="1"
                                     KeyDown="Input_KeyDown">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Style.Triggers>
                                            <Trigger Property="Text" Value="">
                                                <Setter Property="Background">
                                                    <Setter.Value>
                                                        <VisualBrush AlignmentX="Left" AlignmentY="Center" Stretch="None">
                                                            <VisualBrush.Visual>
                                                                <Label Content="vas@email.com" FontSize="14" Foreground="#CCCCCC" Padding="14,0,0,0"/>
                                                            </VisualBrush.Visual>
                                                        </VisualBrush>
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>

                            <TextBlock Text="Heslo" FontSize="12" FontWeight="SemiBold"
                                       Foreground="#555555" Margin="0,0,0,6"/>
                            <Grid Margin="0,0,0,26">
                                <PasswordBox x:Name="RegisterHeslo"
                                             Height="52" FontSize="15" Padding="16,0"
                                             VerticalContentAlignment="Center"
                                             PasswordChanged="RegisterHeslo_PasswordChanged"
                                             KeyDown="Input_KeyDown">
                                    <PasswordBox.Style>
                                        <Style TargetType="PasswordBox">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="PasswordBox">
                                                        <Border Background="#F8F8F8" BorderBrush="#E8E8E8"
                                                                BorderThickness="1" CornerRadius="4">
                                                            <ScrollViewer x:Name="PART_ContentHost" Margin="14,0"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </PasswordBox.Style>
                                </PasswordBox>
                                <TextBlock x:Name="RegisterHesloHint" Text="••••••••"
                                           Padding="14,0,0,0" FontSize="15" Foreground="#CCCCCC"
                                           VerticalAlignment="Center" IsHitTestVisible="False"/>
                            </Grid>

                            <Button Click="Button_Click"
                                    Content="Registrovať sa"
                                    Height="54" FontSize="16" FontWeight="SemiBold"
                                    Background="#111111" Foreground="White" BorderThickness="0">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
