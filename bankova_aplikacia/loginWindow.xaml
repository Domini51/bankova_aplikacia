<Window x:Class="bankova_aplikacia.loginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Investičná Banka"
        Height="700" Width="1100"
        MinHeight="500" MinWidth="800"
        WindowState="Maximized"
        Background="#F2F2F7">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="520"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ===== ĽAVÁ STRANA – branding ===== -->
        <Border Grid.Column="0"
                Background="White"
                BorderBrush="#EBEBEB"
                BorderThickness="0,0,1,0">

            <!-- dekoratívne kruhy v pozadí -->
            <Grid ClipToBounds="True">
                <Ellipse Width="420" Height="420"
                         HorizontalAlignment="Left" VerticalAlignment="Top"
                         Margin="-180,-160,0,0"
                         Fill="#F7F7F7"/>
                <Ellipse Width="300" Height="300"
                         HorizontalAlignment="Right" VerticalAlignment="Bottom"
                         Margin="0,0,-120,-120"
                         Fill="#F7F7F7"/>

                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Width="300">

                    <Image Source="/Assets/investicna_banka_logo-1-removebg-preview.png.png"
                           Height="56"
                           HorizontalAlignment="Left"
                           RenderOptions.BitmapScalingMode="HighQuality"/>

                    <TextBlock Text="Investičná Banka"
                               FontSize="26"
                               FontWeight="Bold"
                               Foreground="#111111"
                               Margin="0,22,0,0"/>

                    <TextBlock Text="Vaše investície na jednom mieste."
                               FontSize="15"
                               Foreground="#8E8E93"
                               Margin="0,8,0,0"
                               TextWrapping="Wrap"/>

                    <Border Height="1" Background="#EBEBEB" Margin="0,36,0,36"/>

                    <!-- value props -->
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <Border Width="5" Height="5" CornerRadius="3"
                                    Background="#111111" Margin="0,5,12,0"
                                    VerticalAlignment="Top"/>
                            <TextBlock Text="Investície do ETF, akcií a kryptomien"
                                       FontSize="14" Foreground="#555555" TextWrapping="Wrap" MaxWidth="260"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <Border Width="5" Height="5" CornerRadius="3"
                                    Background="#111111" Margin="0,5,12,0"
                                    VerticalAlignment="Top"/>
                            <TextBlock Text="AI investičný asistent v reálnom čase"
                                       FontSize="14" Foreground="#555555" TextWrapping="Wrap" MaxWidth="260"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Border Width="5" Height="5" CornerRadius="3"
                                    Background="#111111" Margin="0,5,12,0"
                                    VerticalAlignment="Top"/>
                            <TextBlock Text="Prehľad portfólia a histórie transakcií"
                                       FontSize="14" Foreground="#555555" TextWrapping="Wrap" MaxWidth="260"/>
                        </StackPanel>
                    </StackPanel>

                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== PRAVÁ STRANA – formulár ===== -->
        <Grid Grid.Column="1">

            <Border Width="420"
                    VerticalAlignment="Center"
                    Background="White"
                    CornerRadius="16"
                    Padding="48,44">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="48"
                                      ShadowDepth="4"
                                      Opacity="0.09"
                                      Color="#000000"
                                      Direction="270"/>
                </Border.Effect>

                <StackPanel>

                    <!-- taby -->
                    <Grid Margin="0,0,0,28">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="Login"
                                Click="BtnLogin_Click"
                                Grid.Column="0"
                                Content="Prihlásenie"
                                Height="40"
                                FontSize="15"
                                FontWeight="SemiBold"
                                Background="Transparent"
                                Foreground="#111111"
                                BorderThickness="0,0,0,2"
                                BorderBrush="#111111"/>
                        <Button x:Name="Register"
                                Click="BtnRegister_Click"
                                Grid.Column="1"
                                Content="Registrácia"
                                Height="40"
                                FontSize="15"
                                FontWeight="Normal"
                                Background="Transparent"
                                Foreground="#AAAAAA"
                                BorderThickness="0,0,0,1"
                                BorderBrush="#E0E0E0"/>
                    </Grid>

                    <!-- LOGIN PANEL -->
                    <Border x:Name="PanelLoginBorder" Visibility="Visible">
                        <StackPanel>

                            <TextBlock Text="Email"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#555555"
                                       Margin="0,0,0,6"/>
                            <TextBox x:Name="LoginMeno"
                                     Height="46"
                                     FontSize="14"
                                     Padding="14,0"
                                     Margin="0,0,0,18"
                                     VerticalContentAlignment="Center"
                                     Background="#F8F8F8"
                                     BorderBrush="#E5E5EA"
                                     BorderThickness="1"
                                     KeyDown="Input_KeyDown">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Style.Triggers>
                                            <Trigger Property="Text" Value="">
                                                <Setter Property="Background">
                                                    <Setter.Value>
                                                        <VisualBrush AlignmentX="Left" AlignmentY="Center" Stretch="None">
                                                            <VisualBrush.Visual>
                                                                <Label Content="vas@email.com" FontSize="14" Foreground="#BBBBBB" Padding="14,0,0,0"/>
                                                            </VisualBrush.Visual>
                                                        </VisualBrush>
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>

                            <TextBlock Text="Heslo"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#555555"
                                       Margin="0,0,0,6"/>
                            <Grid Margin="0,0,0,24">
                                <PasswordBox x:Name="LoginHeslo"
                                             Height="46"
                                             FontSize="14"
                                             Padding="14,0"
                                             VerticalContentAlignment="Center"
                                             PasswordChanged="LoginHeslo_PasswordChanged"
                                             KeyDown="Input_KeyDown">
                                    <PasswordBox.Style>
                                        <Style TargetType="PasswordBox">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="PasswordBox">
                                                        <Border Background="#F8F8F8"
                                                                BorderBrush="#E5E5EA"
                                                                BorderThickness="1"
                                                                CornerRadius="6">
                                                            <ScrollViewer x:Name="PART_ContentHost" Margin="14,0"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </PasswordBox.Style>
                                </PasswordBox>
                                <TextBlock x:Name="LoginHesloHint"
                                           Text="••••••••"
                                           Padding="14,0,0,0"
                                           FontSize="15"
                                           Foreground="#BBBBBB"
                                           VerticalAlignment="Center"
                                           IsHitTestVisible="False"/>
                            </Grid>

                            <Button x:Name="MainButton"
                                    Click="Button_Click"
                                    Content="Prihlásiť sa"
                                    Height="48"
                                    FontSize="15"
                                    FontWeight="SemiBold"
                                    Margin="0,0,0,14"
                                    Background="#111111"
                                    Foreground="White"
                                    BorderThickness="0"/>

                            <Button x:Name="ForgotPasswordButton"
                                    Click="Button_Click_1"
                                    Content="Zabudnuté heslo?"
                                    FontSize="13"
                                    Background="Transparent"
                                    Foreground="#AAAAAA"
                                    BorderThickness="0"
                                    HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- REGISTER PANEL -->
                    <Border x:Name="PanelRegisterBorder" Visibility="Collapsed">
                        <StackPanel>

                            <TextBlock Text="Meno"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#555555"
                                       Margin="0,0,0,6"/>
                            <TextBox x:Name="RegisterMeno"
                                     Height="46"
                                     FontSize="14"
                                     Padding="14,0"
                                     Margin="0,0,0,16"
                                     VerticalContentAlignment="Center"
                                     Background="#F8F8F8"
                                     BorderBrush="#E5E5EA"
                                     BorderThickness="1"
                                     KeyDown="Input_KeyDown">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Style.Triggers>
                                            <Trigger Property="Text" Value="">
                                                <Setter Property="Background">
                                                    <Setter.Value>
                                                        <VisualBrush AlignmentX="Left" AlignmentY="Center" Stretch="None">
                                                            <VisualBrush.Visual>
                                                                <Label Content="Vaše meno" FontSize="14" Foreground="#BBBBBB" Padding="14,0,0,0"/>
                                                            </VisualBrush.Visual>
                                                        </VisualBrush>
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>

                            <TextBlock Text="Email"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#555555"
                                       Margin="0,0,0,6"/>
                            <TextBox x:Name="RegisterGmail"
                                     Height="46"
                                     FontSize="14"
                                     Padding="14,0"
                                     Margin="0,0,0,16"
                                     VerticalContentAlignment="Center"
                                     Background="#F8F8F8"
                                     BorderBrush="#E5E5EA"
                                     BorderThickness="1"
                                     KeyDown="Input_KeyDown">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Style.Triggers>
                                            <Trigger Property="Text" Value="">
                                                <Setter Property="Background">
                                                    <Setter.Value>
                                                        <VisualBrush AlignmentX="Left" AlignmentY="Center" Stretch="None">
                                                            <VisualBrush.Visual>
                                                                <Label Content="vas@email.com" FontSize="14" Foreground="#BBBBBB" Padding="14,0,0,0"/>
                                                            </VisualBrush.Visual>
                                                        </VisualBrush>
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>

                            <TextBlock Text="Heslo"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#555555"
                                       Margin="0,0,0,6"/>
                            <Grid Margin="0,0,0,24">
                                <PasswordBox x:Name="RegisterHeslo"
                                             Height="46"
                                             FontSize="14"
                                             Padding="14,0"
                                             VerticalContentAlignment="Center"
                                             PasswordChanged="RegisterHeslo_PasswordChanged"
                                             KeyDown="Input_KeyDown">
                                    <PasswordBox.Style>
                                        <Style TargetType="PasswordBox">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="PasswordBox">
                                                        <Border Background="#F8F8F8"
                                                                BorderBrush="#E5E5EA"
                                                                BorderThickness="1"
                                                                CornerRadius="6">
                                                            <ScrollViewer x:Name="PART_ContentHost" Margin="14,0"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </PasswordBox.Style>
                                </PasswordBox>
                                <TextBlock x:Name="RegisterHesloHint"
                                           Text="••••••••"
                                           Padding="14,0,0,0"
                                           FontSize="15"
                                           Foreground="#BBBBBB"
                                           VerticalAlignment="Center"
                                           IsHitTestVisible="False"/>
                            </Grid>

                            <Button Click="Button_Click"
                                    Content="Registrovať sa"
                                    Height="48"
                                    FontSize="15"
                                    FontWeight="SemiBold"
                                    Background="#111111"
                                    Foreground="White"
                                    BorderThickness="0"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
