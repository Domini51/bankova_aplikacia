<Window x:Class="bankova_aplikacia.loginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:bankova_aplikacia"
        mc:Ignorable="d"
        Title="Investičná Banka" Height="450" Width="800"
        MinHeight="400" MinWidth="600"
        Background="#F5F5F5">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- login register tlacidla -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" Margin="15,10">
            <Button x:Name="Login" Content="Login" Click="BtnLogin_Click"
                    Width="90" Height="30" Background="#555555" FontSize="14"
                    Foreground="White" BorderThickness="0" Margin="0,0,6,0"/>
            <Button x:Name="Register" Content="Register" Click="BtnRegister_Click"
                    Width="90" Height="30" Background="#1A1A1A" FontSize="14"
                    Foreground="White" BorderThickness="0"/>
        </StackPanel>

        <!-- logo banky -->
        <Image Grid.Row="1"
               Source="/Assets/investicna_banka_logo-1-removebg-preview.png.png"
               HorizontalAlignment="Center" VerticalAlignment="Top"
               Width="226" Height="90"
               RenderOptions.BitmapScalingMode="HighQuality"
               Margin="0,5,0,0"/>

        <!-- login formular -->
        <Border x:Name="PanelLoginBorder" Grid.Row="2"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Width="320" Background="White" CornerRadius="8"
                Padding="24,20" Visibility="Visible">
            <StackPanel x:Name="PanelLogin">

                <!-- meno -->
                <TextBox x:Name="LoginMeno" Height="38" Margin="0,0,0,10"
                         FontSize="14" Padding="10,9" BorderBrush="#D0D0D0" BorderThickness="1">
                    <TextBox.Style>
                        <Style TargetType="{x:Type TextBox}">
                            <Style.Triggers>
                                <Trigger Property="Text" Value="">
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <VisualBrush AlignmentX="Left" AlignmentY="Center" Stretch="None">
                                                <VisualBrush.Visual>
                                                    <Label Content="Meno" FontSize="14" Foreground="#AAAAAA"/>
                                                </VisualBrush.Visual>
                                            </VisualBrush>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <!-- heslo -->
                <Grid>
                    <PasswordBox x:Name="LoginHeslo" Height="38" FontSize="14"
                                 Padding="0" BorderBrush="#D0D0D0"
                                 PasswordChanged="LoginHeslo_PasswordChanged">
                        <PasswordBox.Style>
                            <Style TargetType="PasswordBox">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="PasswordBox">
                                            <Border Background="White" BorderBrush="#D0D0D0"
                                                    BorderThickness="1" CornerRadius="3">
                                                <ScrollViewer x:Name="PART_ContentHost" Margin="10,9"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </PasswordBox.Style>
                    </PasswordBox>
                    <TextBlock x:Name="LoginHesloHint" Text="Heslo"
                               Foreground="#AAAAAA" FontSize="14"
                               Padding="11,11,0,0" IsHitTestVisible="False"
                               Visibility="Visible"/>
                </Grid>

            </StackPanel>
        </Border>

        <!-- register formular -->
        <Border x:Name="PanelRegisterBorder" Grid.Row="2"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Width="320" Background="White" CornerRadius="8"
                Padding="24,20" Visibility="Collapsed">
            <StackPanel x:Name="PanelRegister">

                <!-- gmail -->
                <TextBox x:Name="RegisterGmail" Height="38" Margin="0,0,0,10"
                         FontSize="14" Padding="10,9" BorderBrush="#D0D0D0" BorderThickness="1">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Style.Triggers>
                                <Trigger Property="Text" Value="">
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <VisualBrush AlignmentX="Left" AlignmentY="Center" Stretch="None">
                                                <VisualBrush.Visual>
                                                    <Label Content="Gmail" FontSize="14" Foreground="#AAAAAA"/>
                                                </VisualBrush.Visual>
                                            </VisualBrush>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <!-- meno -->
                <TextBox x:Name="RegisterMeno" Height="38" Margin="0,0,0,10"
                         FontSize="14" Padding="10,9" BorderBrush="#D0D0D0" BorderThickness="1">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Style.Triggers>
                                <Trigger Property="Text" Value="">
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <VisualBrush AlignmentX="Left" AlignmentY="Center" Stretch="None">
                                                <VisualBrush.Visual>
                                                    <Label Content="Meno" FontSize="14" Foreground="#AAAAAA"/>
                                                </VisualBrush.Visual>
                                            </VisualBrush>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <!-- heslo -->
                <Grid>
                    <PasswordBox x:Name="RegisterHeslo" Height="38" FontSize="14"
                                 Padding="0" BorderBrush="#D0D0D0"
                                 PasswordChanged="RegisterHeslo_PasswordChanged">
                        <PasswordBox.Style>
                            <Style TargetType="PasswordBox">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="PasswordBox">
                                            <Border Background="White" BorderBrush="#D0D0D0"
                                                    BorderThickness="1" CornerRadius="3">
                                                <ScrollViewer x:Name="PART_ContentHost" Margin="10,9"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </PasswordBox.Style>
                    </PasswordBox>
                    <TextBlock x:Name="RegisterHesloHint" Text="Heslo"
                               Foreground="#AAAAAA" FontSize="14"
                               Padding="11,11,0,0" IsHitTestVisible="False"
                               Visibility="Visible"/>
                </Grid>

            </StackPanel>
        </Border>

        <!-- dolne tlacidlo -->
        <Button x:Name="MainButton" Grid.Row="3" Content="Login"
                Click="Button_Click" Margin="40,10,40,20" Height="46"
                Background="#1A1A1A" Foreground="White" FontSize="18"
                FontWeight="SemiBold" BorderThickness="0" IsDefault="True"/>
        <!-- zabudnute heslo -->
        <Button Content="Forgot password?" 
                Grid.Row="2" 
                Name="ForgotPasswordButton"
                Background="#F5F5F5" 
                Foreground="#555555"
                FontWeight="SemiBold" 
                BorderBrush="White"
                BorderThickness="0" 
                HorizontalAlignment="Center" 
                Width="218" Height="28"
                VerticalAlignment="Bottom"
                Click="Button_Click_1"/>
    </Grid>
</Window>