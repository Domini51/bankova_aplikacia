<Window x:Class="bankova_aplikacia.Window1"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:bankova_aplikacia"
        mc:Ignorable="d"
        Title="Investičná Banka" Height="450" Width="800"
        MinHeight="400" MinWidth="600">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                <GradientStop Color="#FFF5F5F5"/>
                <GradientStop Color="#FF2F4356" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- login register-->
        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
            <Button x:Name="Login"
                    Content="Login"
                    Click="BtnLogin_Click"
                    Width="95" Height="32"
                    Background="#FFB0B0B0"
                    FontSize="20"
                    Foreground="White"
                    BorderBrush="#FF9E9E9E"
                    Margin="0,0,5,0"/>
            <Button x:Name="Register"
                    Content="Register"
                    Click="BtnRegister_Click"
                    Width="95" Height="32"
                    Background="#FFD0D0D0"
                    FontSize="20"
                    Foreground="White"
                    BorderBrush="#FFBDBDBD"/>
        </StackPanel>

        <Image Grid.Row="1"
               Source="pack://application:,,,/Assets/investicna_banka_logo-1-removebg-preview.png"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               Width="250" Height="100"
               RenderOptions.BitmapScalingMode="HighQuality"/>

        <!-- Formulár Login -->
        <StackPanel x:Name="PanelLogin" Grid.Row="2"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="300"
                    Visibility="Visible">
            <TextBox x:Name="LoginMeno"
                     Height="35" Margin="0,0,0,10"
                     FontSize="16" Padding="5"
                     BorderBrush="#FFBDBDBD">
                <TextBox.Style>
                    <Style TargetType="{x:Type TextBox}">
                        <Style.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter Property="Background">
                                    <Setter.Value>
                                        <VisualBrush AlignmentX="Left" AlignmentY="Center" Stretch="None">
                                            <VisualBrush.Visual>
                                                <Label Content="Meno" FontSize="16" Foreground="#FF9E9E9E"/>
                                            </VisualBrush.Visual>
                                        </VisualBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TextBox.Style>
            </TextBox>
            <Grid Margin="0,0,0,10">
                <PasswordBox x:Name="LoginHeslo"
                             Height="35"
                             FontSize="16" Padding="5"
                             BorderBrush="#FFBDBDBD">
                    <PasswordBox.Style>
                        <Style TargetType="PasswordBox">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="PasswordBox">
                                        <Border Background="White"
                                                BorderBrush="#FFBDBDBD"
                                                BorderThickness="1"
                                                CornerRadius="3">
                                            <ScrollViewer x:Name="PART_ContentHost" Margin="5"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </PasswordBox.Style>
                </PasswordBox>
                <TextBlock
                           Foreground="#FF9E9E9E"
                           FontSize="16"
                           Padding="7,4,0,0"
                           IsHitTestVisible="False">
                    <TextBlock.Style>
                        <Style TargetType="{x:Type TextBlock}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Password, ElementName=LoginHeslo}" Value="">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </StackPanel>

        <!-- Formulár Register -->
        <StackPanel x:Name="PanelRegister" Grid.Row="2"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="300"
                    Visibility="Collapsed">
            <TextBox x:Name="RegisterGmail"
                     Height="35" Margin="0,0,0,10"
                     FontSize="16" Padding="5" BorderBrush="#FFBDBDBD">
                <TextBox.Style>
                    <Style TargetType="TextBox">
                        <Style.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter Property="Background">
                                    <Setter.Value>
                                        <VisualBrush AlignmentX="Left" AlignmentY="Center" Stretch="None">
                                            <VisualBrush.Visual>
                                                <Label Content="Gmail" FontSize="16" Foreground="#FF9E9E9E"/>
                                            </VisualBrush.Visual>
                                        </VisualBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TextBox.Style>
            </TextBox>
            <TextBox x:Name="RegisterMeno"
                     Height="35" Margin="0,0,0,10"
                     FontSize="16" Padding="5" BorderBrush="#FFBDBDBD">
                <TextBox.Style>
                    <Style TargetType="TextBox">
                        <Style.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter Property="Background">
                                    <Setter.Value>
                                        <VisualBrush AlignmentX="Left" AlignmentY="Center" Stretch="None">
                                            <VisualBrush.Visual>
                                                <Label Content="Meno" FontSize="16" Foreground="#FF9E9E9E"/>
                                            </VisualBrush.Visual>
                                        </VisualBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TextBox.Style>
            </TextBox>
            <Grid Margin="0,0,0,10">
                <PasswordBox x:Name="RegisterHeslo"
                             Height="35"
                             FontSize="16" Padding="5"
                             BorderBrush="#FFBDBDBD">
                    <PasswordBox.Style>
                        <Style TargetType="PasswordBox">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="PasswordBox">
                                        <Border Background="White"
                                                BorderBrush="#FFBDBDBD"
                                                BorderThickness="1"
                                                CornerRadius="3">
                                            <ScrollViewer x:Name="PART_ContentHost" Margin="5"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </PasswordBox.Style>
                </PasswordBox>
                <TextBlock
                           Foreground="#FF9E9E9E"
                           FontSize="16"
                           Padding="7,8,0,0"
                           IsHitTestVisible="False">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ElementName=RegisterHeslo, Path=Password}" Value="">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </StackPanel>

        <!-- Hlavné tlačidlo -->
        <Button x:Name="MainButton"
                Grid.Row="3"
                Content="Login"
                Click="Button_Click"
                Margin="50,10,50,20"
                Height="73"
                Background="#FFB5BABD"
                Foreground="White"
                FontSize="48"
                BorderBrush="#FFBDBDBD"/>
    </Grid>
</Window>