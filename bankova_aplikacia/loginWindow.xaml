<Window x:Class="bankova_aplikacia.loginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:bankova_aplikacia"
        mc:Ignorable="d"
        WindowState="Maximized"
        Title="Investičná Banka" Height="600" Width="1000"
        MinHeight="400" MinWidth="700">

    <Grid Background="Black">
        <Grid.ColumnDefinitions>
            <!-- lava tmava strana -->
            <ColumnDefinition Width="550"/>
            <!-- prava biela strana -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ===== LAVA STRANA ===== -->
        <Grid Grid.Column="0">
            <Grid.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="Black"/>
                    <GradientStop Color="Black" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Image Source="/Assets/investicna_banka_logo-1-removebg-preview.png.png"
                       Width="200" HorizontalAlignment="Center"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       Margin="0,0,0,24"/>
                <Border Height="2" Width="40" Background="White" Margin="0,0,0,24"/>
                <TextBlock Text="Spravujte svoje financie"
                           FontSize="14" Foreground="#666666"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="a investície na jednom mieste."
                           FontSize="14" Foreground="#666666"
                           HorizontalAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>
        </Grid>

        <!-- ===== PRAVA STRANA ===== -->
        <Grid Grid.Column="1" Background="#F5F5F5">
            <Border Background="White"
                    CornerRadius="12"
                    BorderBrush="#E0E0E0"
                    BorderThickness="1"
                    Padding="48,44"
                    Width="420"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">
                <StackPanel>

                    <!-- taby prihlasenie / registracia -->
                    <Grid Margin="0,0,0,28">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="Login"
                                Grid.Column="0"
                                Content="Prihlásenie"
                                Height="42" FontSize="15"
                                Background="Transparent"
                                Foreground="#1A1A1A"
                                FontWeight="SemiBold"
                                BorderThickness="0,0,0,2"
                                BorderBrush="#1A1A1A"
                                Click="BtnLogin_Click"/>
                        <Button x:Name="Register"
                                Grid.Column="1"
                                Content="Registrácia"
                                Height="42" FontSize="15"
                                Background="Transparent"
                                Foreground="#AAAAAA"
                                FontWeight="Normal"
                                BorderThickness="0,0,0,1"
                                BorderBrush="#E0E0E0"
                                Click="BtnRegister_Click"/>
                    </Grid>

                    <!-- ===== LOGIN PANEL ===== -->
                    <Border x:Name="PanelLoginBorder" Visibility="Visible">
                        <StackPanel>

                            <!-- email -->
                            <TextBlock Text="Email" FontSize="13"
                                       Foreground="#888888" Margin="0,0,0,6"/>
                            <TextBox x:Name="LoginMeno"
                                     Height="46" FontSize="15"
                                     Padding="14,10" Margin="0,0,0,16"
                                     BorderBrush="#E0E0E0" BorderThickness="1">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Style.Triggers>
                                            <Trigger Property="Text" Value="">
                                                <Setter Property="Background">
                                                    <Setter.Value>
                                                        <VisualBrush AlignmentX="Left" AlignmentY="Center" Stretch="None">
                                                            <VisualBrush.Visual>
                                                                <Label Content="vas@email.com" FontSize="14" Foreground="#BBBBBB"/>
                                                            </VisualBrush.Visual>
                                                        </VisualBrush>
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>

                            <!-- heslo -->
                            <TextBlock Text="Heslo" FontSize="13"
                                       Foreground="#888888" Margin="0,0,0,6"/>
                            <Grid Margin="0,0,0,20">
                                <PasswordBox x:Name="LoginHeslo"
                                             Height="46" FontSize="15"
                                             Padding="14,10"
                                             PasswordChanged="LoginHeslo_PasswordChanged">
                                    <PasswordBox.Style>
                                        <Style TargetType="PasswordBox">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="PasswordBox">
                                                        <Border Background="White"
                                                                BorderBrush="#E0E0E0"
                                                                BorderThickness="1"
                                                                CornerRadius="3">
                                                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </PasswordBox.Style>
                                </PasswordBox>
                                <TextBlock x:Name="LoginHesloHint"
                                           Text="••••••••"
                                           Foreground="#BBBBBB" FontSize="15"
                                           Padding="14,10,0,0"
                                           IsHitTestVisible="False"
                                           Visibility="Visible"/>
                            </Grid>

                            <!-- hlavne tlacidlo -->
                            <Button x:Name="MainButton"
                                    Content="Prihlásiť sa"
                                    Height="48" FontSize="16"
                                    FontWeight="SemiBold"
                                    Background="#1A1A1A"
                                    Foreground="White"
                                    BorderThickness="0"
                                    Margin="0,0,0,14"
                                    Click="Button_Click"/>

                            <!-- zabudnute heslo -->
                            <Button x:Name="ForgotPasswordButton"
                                    Content="Zabudnuté heslo?"
                                    Background="Transparent"
                                    Foreground="#888888"
                                    BorderThickness="0"
                                    FontSize="13"
                                    HorizontalAlignment="Center"
                                    Click="Button_Click_1"/>

                        </StackPanel>
                    </Border>

                    <!-- ===== REGISTER PANEL ===== -->
                    <Border x:Name="PanelRegisterBorder" Visibility="Collapsed">
                        <StackPanel>

                            <!-- meno -->
                            <TextBlock Text="Meno" FontSize="13"
                                       Foreground="#888888" Margin="0,0,0,6"/>
                            <TextBox x:Name="RegisterMeno"
                                     Height="46" FontSize="15"
                                     Padding="14,10" Margin="0,0,0,16"
                                     BorderBrush="#E0E0E0" BorderThickness="1">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Style.Triggers>
                                            <Trigger Property="Text" Value="">
                                                <Setter Property="Background">
                                                    <Setter.Value>
                                                        <VisualBrush AlignmentX="Left" AlignmentY="Center" Stretch="None">
                                                            <VisualBrush.Visual>
                                                                <Label Content="Vaše meno" FontSize="14" Foreground="#BBBBBB"/>
                                                            </VisualBrush.Visual>
                                                        </VisualBrush>
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>

                            <!-- email -->
                            <TextBlock Text="Email" FontSize="13"
                                       Foreground="#888888" Margin="0,0,0,6"/>
                            <TextBox x:Name="RegisterGmail"
                                     Height="46" FontSize="15"
                                     Padding="14,10" Margin="0,0,0,16"
                                     BorderBrush="#E0E0E0" BorderThickness="1">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Style.Triggers>
                                            <Trigger Property="Text" Value="">
                                                <Setter Property="Background">
                                                    <Setter.Value>
                                                        <VisualBrush AlignmentX="Left" AlignmentY="Center" Stretch="None">
                                                            <VisualBrush.Visual>
                                                                <Label Content="vas@email.com" FontSize="14" Foreground="#BBBBBB"/>
                                                            </VisualBrush.Visual>
                                                        </VisualBrush>
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>

                            <!-- heslo -->
                            <TextBlock Text="Heslo" FontSize="13"
                                       Foreground="#888888" Margin="0,0,0,6"/>
                            <Grid Margin="0,0,0,20">
                                <PasswordBox x:Name="RegisterHeslo"
                                             Height="46" FontSize="15"
                                             Padding="14,10"
                                             PasswordChanged="RegisterHeslo_PasswordChanged">
                                    <PasswordBox.Style>
                                        <Style TargetType="PasswordBox">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="PasswordBox">
                                                        <Border Background="White"
                                                                BorderBrush="#E0E0E0"
                                                                BorderThickness="1"
                                                                CornerRadius="3">
                                                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </PasswordBox.Style>
                                </PasswordBox>
                                <TextBlock x:Name="RegisterHesloHint"
                                           Text="••••••••"
                                           Foreground="#BBBBBB" FontSize="15"
                                           Padding="14,10,0,0"
                                           IsHitTestVisible="False"
                                           Visibility="Visible"/>
                            </Grid>

                            <!-- hlavne tlacidlo register -->
                            <Button Content="Registrovať sa"
                                    Height="48" FontSize="16"
                                    FontWeight="SemiBold"
                                    Background="#1A1A1A"
                                    Foreground="White"
                                    BorderThickness="0"
                                    Click="Button_Click"/>

                        </StackPanel>
                    </Border>

                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>